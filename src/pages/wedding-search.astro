const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SearchResultsPage",
  "name": "Wedding Search Results",
  "description": "Find your perfect destination wedding venue with our advanced search filters.",
  "url": `${SITE.url}/wedding-search`
};
---

<BaseLayout title="Wedding Search Results | The Wedding Travel Company" jsonLd={jsonLd}>
  <main class="py-16 md:py-24 bg-surface min-h-screen" data-ps="src/pages/wedding-search.astro:ixs91v">
    <div class="max-w-7xl mx-auto px-6" data-ps="src/pages/wedding-search.astro:ag67t8">
      <div class="max-w-3xl mb-16" data-ps="src/pages/wedding-search.astro:ag67t9">
        <h1 class="text-[42px] md:text-[56px] font-bold font-serif text-secondary mb-6 leading-tight" data-ps="src/pages/wedding-search.astro:x23lg2">
          Find Your <span class="text-primary italic" data-ps="src/pages/wedding-search.astro:3snghc">Dream Venue</span>
        </h1>
        <p class="text-lg text-muted-foreground leading-relaxed" data-ps="src/pages/wedding-search.astro:8g54l">
          Explore our hand-picked collection of premium wedding venues across the globe. From sun-drenched Mediterranean terraces to exotic beachfront escapes.
        </p>
      </div>
      
      <WeddingSearchIsland client:load venues={venues} />
    </div>
  </main>
</BaseLayout>
