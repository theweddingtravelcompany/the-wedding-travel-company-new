---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Portugal Destination Weddings - The Wedding Travel Company" description="Design your dream wedding in Portugal.">
  <div class="py-24 px-6 text-center max-w-4xl mx-auto min-h-[60vh] flex flex-col justify-center" data-ps="src/pages/destinations/portugal.astro:ydknhq">
    <h1 class="text-5xl font-serif font-bold text-secondary mb-6" data-ps="src/pages/destinations/portugal.astro:j469ax">Portugal Weddings</h1>
    <p class="text-muted-foreground text-lg mb-8" data-ps="src/pages/destinations/portugal.astro:qfly1e">We are curating our finest venues in Portugal. Check back soon for breathtaking Algarve and Lisbon locations.</p>
    <a href="/destinations/all-destinations" class="bg-primary text-white px-8 py-4 rounded-xl font-bold uppercase tracking-widest text-sm inline-block w-max mx-auto" data-ps="src/pages/destinations/portugal.astro:qnv627">Explore All Destinations</a>
  </div>
</BaseLayout>