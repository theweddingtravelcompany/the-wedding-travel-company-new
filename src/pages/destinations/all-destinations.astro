---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AllDestinationsHero from '@/components/destinations/AllDestinationsHero.astro';

import EuropeanDestinations from '@/components/home/EuropeanDestinations.astro';
import LongHaulParadise from '@/components/home/LongHaulParadise.astro';
import FeaturedCollection from '@/components/home/FeaturedCollection.astro';
---

<BaseLayout 
  title="All Wedding Destinations | The Wedding Travel Company" 
  description="Explore our award-winning destination wedding locations across the globe. From Cyprus and Greece to Italy and Las Vegas."
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "All Wedding Destinations",
    "description": "Explore our award-winning destination wedding locations across the globe.",
    "url": "https://twtc-site.pagesmith.app/destinations/all-destinations/"
  }}
>
  <AllDestinationsHero />

  <FeaturedCollection />

  <div class="pt-24 bg-surface" data-ps="src/pages/destinations/all-destinations.astro:xhzhc2">
    <div class="text-center max-w-7xl mx-auto px-6" data-ps="src/pages/destinations/all-destinations.astro:xhzhc1">
      <h2 class="text-[42px] font-bold font-serif text-secondary mb-4" data-ps="src/pages/destinations/all-destinations.astro:wbfb39">Find Your Perfect Wedding Destination</h2>
      <p class="text-muted-foreground max-w-2xl mx-auto" data-ps="src/pages/destinations/all-destinations.astro:3piq2q">Whether you're dreaming of a Mediterranean beach ceremony, a romantic Italian villa, or a vibrant Las Vegas celebration, explore our carefully selected destinations below.</p>
    </div>
  </div>

  <EuropeanDestinations />
  <LongHaulParadise />

  <!-- Content Blocks -->
  <section class="py-24 px-6 bg-white border-t border-stone-100" data-ps="src/pages/destinations/all-destinations.astro:hv32ne">
    <div class="max-w-7xl mx-auto space-y-32" data-ps="src/pages/destinations/all-destinations.astro:qz4w7k">
      <!-- Award Winning -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-24 items-center" data-ps="src/pages/destinations/all-destinations.astro:qz4w7l">
        <div class="order-2 md:order-1" data-ps="src/pages/destinations/all-destinations.astro:qz4w7m">
          <span class="inline-block px-3 py-1 bg-[#FDF2F9] text-[#A81E82] text-[10px] font-bold tracking-widest uppercase rounded-full mb-6" data-ps="src/pages/destinations/all-destinations.astro:8dhzd7">Excellence</span>
          <h2 class="text-4xl md:text-5xl font-serif text-secondary mb-6" data-ps="src/pages/destinations/all-destinations.astro:7els4k">Award-Winning Wedding Specialists</h2>
          <p class="text-muted-foreground text-lg leading-relaxed mb-8" data-ps="src/pages/destinations/all-destinations.astro:r33nm0">
            At The Wedding Travel Company, we understand that your wedding day is one of the most important moments of your life. That's why our team of award-winning specialists is dedicated to helping you find the perfect destination for your "I do's".
          </p>
          <a href="/enquire2" class="inline-block text-[#A81E82] font-bold text-xs tracking-widest uppercase border-b-2 border-[#A81E82] pb-1 hover:text-accent-hover hover:border-accent-hover transition-colors" data-ps="src/pages/destinations/all-destinations.astro:y71kb5">
            Get Your Quote
          </a>
        </div>
        <div class="order-1 md:order-2" data-ps="src/pages/destinations/all-destinations.astro:xhzhca">
          <div class="relative" data-ps="src/pages/destinations/all-destinations.astro:xhzhc9">
            <div class="absolute inset-0 bg-[#FDF2F9] rounded-3xl translate-x-4 translate-y-4 -z-10" data-ps="src/pages/destinations/all-destinations.astro:xhzhc8"></div>
            <div class="aspect-[4/3] rounded-3xl overflow-hidden shadow-2xl shadow-stone-200" data-ps="src/pages/destinations/all-destinations.astro:xhzhc7">
              <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1519741497674-611481863552?auto=format&w=1200&q=80" alt="Wedding Celebration" class="w-full h-full object-cover" loading="lazy" data-ps="src/pages/destinations/all-destinations.astro:ogvrw2" />
            </div>
          </div>
        </div>
      </div>

      <!-- Expert Guidance -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-24 items-center" data-ps="src/pages/destinations/all-destinations.astro:xhzhc6">
        <div class="order-1" data-ps="src/pages/destinations/all-destinations.astro:xhzhc5">
          <div class="relative" data-ps="src/pages/destinations/all-destinations.astro:xhzhc4">
            <div class="absolute inset-0 bg-[#F5F5F5] rounded-3xl -translate-x-4 translate-y-4 -z-10" data-ps="src/pages/destinations/all-destinations.astro:xhzhc3"></div>
            <div class="aspect-[4/3] rounded-3xl overflow-hidden shadow-2xl shadow-stone-200" data-ps="src/pages/destinations/all-destinations.astro:xhzhc2">
              <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1511795409834-ef04bbd61622?auto=format&w=1200&q=80" alt="Wedding Planning" class="w-full h-full object-cover" loading="lazy" data-ps="src/pages/destinations/all-destinations.astro:ogvrw3" />
            </div>
          </div>
        </div>
        <div class="order-2" data-ps="src/pages/destinations/all-destinations.astro:xhzhc1">
          <span class="inline-block px-3 py-1 bg-[#F5F5F5] text-muted-foreground text-[10px] font-bold tracking-widest uppercase rounded-full mb-6" data-ps="src/pages/destinations/all-destinations.astro:8dhzdt">Expertise</span>
          <h2 class="text-4xl md:text-5xl font-serif text-secondary mb-6" data-ps="src/pages/destinations/all-destinations.astro:7els4l">Expert Guidance Every Step of the Way</h2>
          <p class="text-muted-foreground text-lg leading-relaxed mb-8" data-ps="src/pages/destinations/all-destinations.astro:r33nm1">
            Our experienced wedding consultants have visited the destinations we offer and can provide first-hand knowledge and advice. We handle all the intricate details of your travel and wedding arrangements, ensuring a stress-free planning experience.
          </p>
          <a href="/enquire2" class="inline-block text-[#A81E82] font-bold text-xs tracking-widest uppercase border-b-2 border-[#A81E82] pb-1 hover:text-accent-hover hover:border-accent-hover transition-colors" data-ps="src/pages/destinations/all-destinations.astro:y71kb6">
            Speak to a Consultant
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>