---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="New York Weddings - The Wedding Travel Company" description="Design your dream wedding in New York.">
  <div class="py-24 px-6 text-center max-w-4xl mx-auto min-h-[60vh] flex flex-col justify-center" data-ps="src/pages/destinations/new-york.astro:x0ij5g">
    <h1 class="text-5xl font-serif font-bold text-secondary mb-6" data-ps="src/pages/destinations/new-york.astro:7nllkr">New York Weddings</h1>
    <p class="text-muted-foreground text-lg mb-8" data-ps="src/pages/destinations/new-york.astro:opz9x0">We are curating our finest venues in New York City. Check back soon for spectacular skyline celebrations.</p>
    <a href="/destinations/all-destinations" class="bg-primary text-white px-8 py-4 rounded-xl font-bold uppercase tracking-widest text-sm inline-block w-max mx-auto" data-ps="src/pages/destinations/new-york.astro:oy8hxt">Explore All Destinations</a>
  </div>
</BaseLayout>