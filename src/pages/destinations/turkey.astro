---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Turkey Destination Weddings - The Wedding Travel Company" description="Design your dream wedding in Turkey.">
  <div class="py-24 px-6 text-center max-w-4xl mx-auto min-h-[60vh] flex flex-col justify-center" data-ps="src/pages/destinations/turkey.astro:9sox9a">
    <h1 class="text-5xl font-serif font-bold text-secondary mb-6" data-ps="src/pages/destinations/turkey.astro:3eh4uv">Turkey Weddings</h1>
    <p class="text-muted-foreground text-lg mb-8" data-ps="src/pages/destinations/turkey.astro:3pvg9u">We are curating our finest venues in Turkey. Check back soon for beautiful coastal and cultural locations.</p>
    <a href="/destinations/all-destinations" class="bg-primary text-white px-8 py-4 rounded-xl font-bold uppercase tracking-widest text-sm inline-block w-max mx-auto" data-ps="src/pages/destinations/turkey.astro:3y4oan">Explore All Destinations</a>
  </div>
</BaseLayout>