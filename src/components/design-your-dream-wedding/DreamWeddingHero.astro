---
// Design Your Dream Wedding Hero
---

<section class="relative bg-secondary min-h-[600px] flex items-center py-20 px-6 overflow-hidden">
  <div class="absolute inset-0 z-0">
    <img
      crossorigin="anonymous"
      src="https://images.unsplash.com/photo-1768611264978-92918fa8e8c3?auto=format&w=1920&q=80"
      alt="Romantic wedding couple on a sunset beach"
      class="w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-secondary/50"></div>
  </div>

  <div class="max-w-7xl mx-auto w-full relative z-10 text-white">
    <h1 class="text-[48px] md:text-[72px] font-bold font-serif leading-tight mb-6">
      Design Your Dream Wedding
    </h1>
    <p class="text-[24px] text-white/80 max-w-2xl mb-10">
      Tell us the vibe you want — we'll match you with beautiful wedding venues across our most breathtaking destinations.
    </p>
    <div class="flex flex-wrap gap-4">
      <a href="#vibe-selector" class="bg-primary text-white px-8 py-4 rounded-xl font-bold uppercase tracking-widest text-[12px] hover:bg-primary-hover transition-colors">
        Explore Wedding Venues
      </a>
      <a href="#shortlist" class="bg-white/10 border border-white/30 text-white px-8 py-4 rounded-xl font-bold uppercase tracking-widest text-[12px] hover:bg-white/20 transition-colors">
        Speak to our team
      </a>
    </div>
  </div>
</section>