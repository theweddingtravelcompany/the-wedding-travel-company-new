<section class="py-24 px-6 bg-surface" data-ps="src/components/design-your-dream-wedding/DreamWeddingFeatured.astro:fhmyms">
  <div class="max-w-7xl mx-auto" data-ps="src/components/design-your-dream-wedding/DreamWeddingFeatured.astro:olji2q">
