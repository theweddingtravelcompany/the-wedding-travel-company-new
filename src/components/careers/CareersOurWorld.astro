---
// Our World Section
---

<section class="py-24 px-6 bg-background">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-[42px] font-bold font-serif text-secondary mb-4">Our World</h2>
      <p class="text-muted-foreground text-lg">From the sun-drenched beaches of the Caribbean to the historic charm of Italy, our portfolio spans the globe's most sought-after wedding locations.</p>
    </div>

    <div class="flex flex-wrap justify-center gap-4 mb-16">
      {['Cyprus', 'Greece', 'Italy', 'Malta', 'Spain', 'Portugal', 'Las Vegas', 'New York', 'Florida', 'Caribbean'].map((dest) => (
        <span class="bg-surface px-6 py-3 rounded-full text-sm font-bold text-secondary">{dest}</span>
      ))}
    </div>

    <div class="rounded-2xl overflow-hidden aspect-[21/9]">
      <img
        crossorigin="anonymous"
        src="https://images.unsplash.com/photo-1519123833858-f99014eb53c7?auto=format&w=1200&q=80"
        alt="Cyprus wedding"
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
  </div>
</section>