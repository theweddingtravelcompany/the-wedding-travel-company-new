---
// Careers Page Hero
---

<section class="relative bg-secondary min-h-[500px] flex items-center py-20 px-6 overflow-hidden">
  <div class="absolute inset-0 z-0">
    <img src="https://cdn.pagesmith.app/4604757a/images/wedding-concierge-hero-1536-1536.webp"
      alt="Luxury wedding"
      class="w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-secondary/50"></div>
  </div>

  <div class="max-w-7xl mx-auto w-full relative z-10 text-white">
    <p class="text-white/60 text-sm font-bold uppercase tracking-widest mb-4">Careers</p>
    <h1 class="text-[48px] md:text-[72px] font-bold font-serif leading-tight mb-6">
      Join The Team
    </h1>
    <h2 class="text-[28px] md:text-[36px] font-bold font-serif text-white/80 mb-6">
      Crafting Unforgettable Memories
    </h2>
    <p class="text-[20px] text-white/80 max-w-2xl leading-relaxed">
      Step into a career that combines luxury travel, premium service, and the magic of destination weddings.
    </p>
    <a
      href="#roles"
      class="inline-block mt-8 bg-primary text-white px-8 py-4 rounded-lg font-bold uppercase tracking-widest text-[12px] hover:bg-primary-hover transition-colors"
    >
      View Open Roles
    </a>
  </div>
</section>