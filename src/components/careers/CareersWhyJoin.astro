---
// Why Join Us Section
---

<section class="py-24 px-6 bg-background">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-[42px] font-bold font-serif text-secondary mb-4">Why Join Us</h2>
      <p class="text-muted-foreground text-lg">Build a rewarding career in an industry filled with celebration and travel.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Uncapped Earnings -->
      <div class="bg-surface p-8 rounded-xl text-center hover-lift">
        <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center shadow-sm text-primary mx-auto mb-6">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h3 class="text-[20px] font-bold text-secondary mb-3">Uncapped Earnings</h3>
        <p class="text-muted-foreground text-sm">Our top performers consistently earn between £3,000 and £5,000+ per month.</p>
      </div>

      <!-- Luxury Travel -->
      <div class="bg-surface p-8 rounded-xl text-center hover-lift">
        <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center shadow-sm text-primary mx-auto mb-6">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h3 class="text-[20px] font-bold text-secondary mb-3">Luxury Travel</h3>
        <p class="text-muted-foreground text-sm">Immerse yourself in the world of high-end resorts and breathtaking destinations.</p>
      </div>

      <!-- Career Growth -->
      <div class="bg-surface p-8 rounded-xl text-center hover-lift">
        <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center shadow-sm text-primary mx-auto mb-6">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
          </svg>
        </div>
        <h3 class="text-[20px] font-bold text-secondary mb-3">Career Growth</h3>
        <p class="text-muted-foreground text-sm">Join a fast-growing company that values ambition, development, and internal promotion.</p>
      </div>

      <!-- Premium Experience -->
      <div class="bg-surface p-8 rounded-xl text-center hover-lift">
        <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center shadow-sm text-primary mx-auto mb-6">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h3 class="text-[20px] font-bold text-secondary mb-3">Premium Experience</h3>
        <p class="text-muted-foreground text-sm">Deliver joy. Help couples plan the most important and magical day of their lives.</p>
      </div>
    </div>
  </div>
</section>