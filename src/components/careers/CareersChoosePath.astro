---
// Choose Your Path Section
---

<section id="roles" class="py-24 px-6 bg-surface">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-[42px] font-bold font-serif text-secondary mb-4">Choose Your Path</h2>
      <p class="text-muted-foreground text-lg">Two distinct roles. One shared vision of excellence.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <!-- Wedding Consultant (Sales) -->
      <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover-lift">
        <div class="aspect-[4/3] overflow-hidden">
          <img src="https://cdn.pagesmith.app/4604757a/images/wedding-consiger-sale-320-320.webp"
            alt="Wedding Consultant"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="p-10">
          <p class="text-[10px] font-bold uppercase tracking-widest text-primary mb-2">Sales Focus</p>
          <h3 class="text-[28px] font-bold font-serif text-secondary mb-4">Wedding Consultant</h3>
          <p class="text-muted-foreground text-sm mb-6 leading-relaxed">
            Commercially driven, highly motivated sales professionals who excel at converting high-value enquiries into booked destination weddings.
          </p>
          <ul class="space-y-2 mb-8 text-sm text-muted-foreground">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              Manages own pipeline & converts enquiries
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              Target-driven with uncapped commission
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              OTE £3,000–£5,000+ per month
            </li>
          </ul>
          <a href="/careers/wedding-consultant" class="block w-full bg-secondary text-white text-center py-4 rounded-xl font-bold uppercase tracking-widest text-[12px] hover:bg-secondary-hover transition-colors">
            Explore Sales Role
          </a>
        </div>
      </div>

      <!-- Wedding Concierge Consultant (Service) -->
      <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover-lift">
        <div class="aspect-[4/3] overflow-hidden">
          <img src="https://cdn.pagesmith.app/4604757a/images/wedding-concierge-320-320.webp"
            alt="Wedding Concierge Consultant"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="p-10">
          <p class="text-[10px] font-bold uppercase tracking-widest text-primary mb-2">Service Focus</p>
          <h3 class="text-[28px] font-bold font-serif text-secondary mb-4">Wedding Concierge Consultant</h3>
          <p class="text-muted-foreground text-sm mb-6 leading-relaxed">
            Highly organised, detail-oriented professionals who handle post-sale client support, bookings, guest arrangements, and supplier coordination.
          </p>
          <ul class="space-y-2 mb-8 text-sm text-muted-foreground">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              Manages post-sale client journey & admin
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              Service-led, incredibly organised
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              Uncapped commission potential
            </li>
          </ul>
          <a href="/careers/wedding-concierge-consultant" class="block w-full bg-secondary text-white text-center py-4 rounded-xl font-bold uppercase tracking-widest text-[12px] hover:bg-secondary-hover transition-colors">
            Explore Concierge Role
          </a>
        </div>
      </div>
    </div>
  </div>
</section>