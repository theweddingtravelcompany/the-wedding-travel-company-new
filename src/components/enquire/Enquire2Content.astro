---
import { SITE } from '@/config/site';
---

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24" data-ps="src/components/enquire/Enquire2Content.astro:lzq09d">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16" data-ps="src/components/enquire/Enquire2Content.astro:lzq09e">
    
    <!-- Main Form Area -->
    <div class="lg:col-span-2" data-ps="src/components/enquire/Enquire2Content.astro:lzq09f">
      <div class="mb-10" data-ps="src/components/enquire/Enquire2Content.astro:lzq09g">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold font-heading text-primary mb-4" data-ps="src/components/enquire/Enquire2Content.astro:yoq88o">Let’s design your perfect wedding abroad</h1>
        <p class="text-lg md:text-xl text-text-muted leading-relaxed" data-ps="src/components/enquire/Enquire2Content.astro:gr40ha">Share a few details and our destination specialists will hand-pick 3–5 venues tailored to your vision, guest count and budget.</p>
        
        <div class="mt-8 flex flex-wrap gap-y-3 gap-x-6 py-4 px-6 bg-surface rounded-2xl border border-border" data-ps="src/components/enquire/Enquire2Content.astro:trust-bar">
          <div class="flex items-center gap-2 text-sm font-medium text-primary" data-ps="src/components/enquire/Enquire2Content.astro:hmczc6">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-green"><polyline points="20 6 9 17 4 12"/></svg>
            No obligation consultation
          </div>
          <div class="flex items-center gap-2 text-sm font-medium text-primary" data-ps="src/components/enquire/Enquire2Content.astro:hmczc5">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-green"><polyline points="20 6 9 17 4 12"/></svg>
            Personal wedding specialist assigned
          </div>
          <div class="flex items-center gap-2 text-sm font-medium text-primary" data-ps="src/components/enquire/Enquire2Content.astro:hmczc4">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-green"><polyline points="20 6 9 17 4 12"/></svg>
            Fast response
          </div>
        </div>
      </div>

      <form class="space-y-8" onsubmit="event.preventDefault(); alert('Enquiry submitted successfully!');">
        
        <!-- Details Section -->
        <div class="space-y-4" data-ps="src/components/enquire/Enquire2Content.astro:lzq09h">
          <h2 class="text-xl font-bold text-primary border-b border-border pb-2" data-ps="src/components/enquire/Enquire2Content.astro:lnywiv">Your Details</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-ps="src/components/enquire/Enquire2Content.astro:lzq09i">
            <div class="space-y-2" data-ps="src/components/enquire/Enquire2Content.astro:lzq09j">
              <label for="fullName" class="block text-sm font-medium text-text" data-ps="src/components/enquire/Enquire2Content.astro:ekm0fu">Full Name *</label>
              <input type="text" id="fullName" required placeholder="e.g. Sarah Jenkins" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-all" />
            </div>
            <div class="space-y-2" data-ps="src/components/enquire/Enquire2Content.astro:lzq0a5">
              <label for="phone" class="block text-sm font-medium text-text" data-ps="src/components/enquire/Enquire2Content.astro:ekm0fv">Phone *</label>
              <input type="tel" id="phone" required placeholder="e.g. 07123 456789" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-all" />
            </div>
            <div class="space-y-2" data-ps="src/components/enquire/Enquire2Content.astro:lzq0a6">
              <label for="email" class="block text-sm font-medium text-text" data-ps="src/components/enquire/Enquire2Content.astro:ekm0fw">Email *</label>
              <input type="email" id="email" required placeholder="e.g. sarah@example.com" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-all" />
            </div>
          </div>
        </div>

        <!-- Preferences Section -->
        <div class="space-y-4 pt-4" data-ps="src/components/enquire/Enquire2Content.astro:lzq0a7">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-ps="src/components/enquire/Enquire2Content.astro:lzq0a8">
            <div class="space-y-2" data-ps="src/components/enquire/Enquire2Content.astro:lzq0a9">
              <label for="destination" class="block text-sm font-medium text-text" data-ps="src/components/enquire/Enquire2Content.astro:ekm0fy">Wedding Destination *</label>
              <select id="destination" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-all bg-white appearance-none">
                <option value="">- Select -</option>
                <option value="Cyprus">Cyprus</option>
                <option value="Las Vegas">Las Vegas</option>
                <option value="Greece">Greece</option>
                <option value="Greece - (Santorini)">Greece - (Santorini)</option>
                <option value="Greece - (Zante)">Greece - (Zante)</option>
                <option value="Greece - (Skiathos)">Greece - (Skiathos)</option>
                <option value="Greece - (Rhodes)">Greece - (Rhodes)</option>
                <option value="Greece - (Corfu)">Greece - (Corfu)</option>
                <option value="Greece - (Crete)">Greece - (Crete)</option>
                <option value="Greece - (Kos)">Greece - (Kos)</option>
                <option value="Greece - (Mykonos)">Greece - (Mykonos)</option>
                <option value="Greece - (Halkidiki)">Greece - (Halkidiki)</option>
                <option value="Greece - (Athens)">Greece - (Athens)</option>
                <option value="Italy">Italy</option>
                <option value="Malta">Malta</option>
                <option value="Turkey">Turkey</option>
                <option value="Croatia">Croatia</option>
                <option value="Spain - (Mainland)">Spain - (Mainland)</option>
                <option value="Spain - (Canary islands)">Spain - (Canary islands)</option>
                <option value="Spain - (Balearic islands)">Spain - (Balearic islands)</option>
                <option value="Portugal">Portugal</option>
                <option value="Mauritius">Mauritius</option>
                <option value="New York">New York</option>
                <option value="Help me choose">Help me choose</option>
              </select>
            </div>

            <div class="space-y-2" data-ps="src/components/enquire/Enquire2Content.astro:lzq0aa">
              <label for="arrival" class="block text-sm font-medium text-text" data-ps="src/components/enquire/Enquire2Content.astro:ekm0fz">Arrival *</label>
              <select id="arrival" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-all bg-white appearance-none">
                <option value="">- Select -</option>
                <option value="2026 - Spring">2026 - Spring</option>
                <option value="2026 - Summer">2026 - Summer</option>
                <option value="2026 - Autumn">2026 - Autumn</option>
                <option value="2027 - Winter">2027 - Winter</option>
                <option value="2027 - Spring">2027 - Spring</option>
                <option value="2027 - Summer">2027 - Summer</option>
                <option value="2027 - Autumn">2027 - Autumn</option>
                <option value="2028 - Winter">2028 - Winter</option>
                <option value="2028 - Spring">2028 - Spring</option>
                <option value="2028 - Summer">2028 - Summer</option>
                <option value="2028 - Autumn">2028 - Autumn</option>
                <option value="2029 - Winter">2029 - Winter</option>
                <option value="2029 - Spring">2029 - Spring</option>
                <option value="2029 - Summer">2029 - Summer</option>
                <option value="2029 - Autumn">2029 - Autumn</option>
              </select>
            </div>

            <div class="space-y-2" data-ps="src/components/enquire/Enquire2Content.astro:lzq0ab">
              <label for="budget" class="block text-sm font-medium text-text" data-ps="src/components/enquire/Enquire2Content.astro:ekm0g0">Budget *</label>
              <select id="budget" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-all bg-white appearance-none">
                <option value="">- Select -</option>
                <option value="Up to £3,000">Up to £3,000</option>
                <option value="Up to £5,000">Up to £5,000</option>
                <option value="Up to £7,500">Up to £7,500</option>
                <option value="Up to £10,000">Up to £10,000</option>
                <option value="Up to £15,000">Up to £15,000</option>
                <option value="£20,000 Plus">£20,000 Plus</option>
              </select>
            </div>

            <div class="space-y-2" data-ps="src/components/enquire/Enquire2Content.astro:lzq0ac">
              <label for="venueSize" class="block text-sm font-medium text-text" data-ps="src/components/enquire/Enquire2Content.astro:ekm0gm">Venue Size *</label>
              <select id="venueSize" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-all bg-white appearance-none">
                <option value="">- Select -</option>
                <option value="Small and Intimate">Small and Intimate (1-24 guests)</option>
                <option value="A Happy Medium">A Happy Medium (25-49 guests)</option>
                <option value="Large Group">Large Group (50-99 guests)</option>
                <option value="A Grand Affair">A Grand Affair (100+ guests)</option>
              </select>
            </div>
          </div>
        </div>

        <!-- Finishing Touches Section -->
        <div class="pt-4" data-ps="src/components/enquire/Enquire2Content.astro:lzq0ad">
          <details class="group border border-gray-300 rounded-xl overflow-hidden bg-white transition-all shadow-sm">
            <summary class="flex items-center justify-between px-4 py-4 cursor-pointer list-none hover:bg-surface transition-colors">
              <span class="text-sm font-medium text-text" data-ps="src/components/enquire/Enquire2Content.astro:jwygzn">Finishing Touches (optional)</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted group-open:rotate-180 transition-transform"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <div class="px-4 pb-6 pt-2 space-y-6" data-ps="src/components/enquire/Enquire2Content.astro:lzq0ae">
              <!-- Logistics Info -->
              <div class="grid grid-cols-1 md:grid-cols-3 gap-6 pt-2" data-ps="src/components/enquire/Enquire2Content.astro:lzq0b1">
                <div class="space-y-2" data-ps="src/components/enquire/Enquire2Content.astro:lzq0b2">
                  <label for="departureAirport" class="block text-sm font-medium text-text" data-ps="src/components/enquire/Enquire2Content.astro:ekm0gp">Departure Airport</label>
                  <input type="text" id="departureAirport" placeholder="e.g. Manchester" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-all" />
                </div>

                <div class="space-y-2" data-ps="src/components/enquire/Enquire2Content.astro:lzq0b3">
                  <label for="duration" class="block text-sm font-medium text-text" data-ps="src/components/enquire/Enquire2Content.astro:ekm0gq">Duration</label>
                  <select id="duration" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-all bg-white appearance-none">
                    <option value="">- Select Duration -</option>
                    <option value="1-3 Days">1-3 Days</option>
                    <option value="4-8 Days">4-8 Days</option>
                    <option value="9-12 Days">9-12 Days</option>
                    <option value="13-15 Days">13-15 Days</option>
                    <option value="16+ Days">16+ Days</option>
                  </select>
                </div>

                <div class="space-y-2" data-ps="src/components/enquire/Enquire2Content.astro:lzq0b4">
                  <label for="guests" class="block text-sm font-medium text-text" data-ps="src/components/enquire/Enquire2Content.astro:ekm0gr">Number of Guests</label>
                  <input type="text" id="guests" placeholder="(Inc bride & groom)" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-all" />
                </div>
              </div>

              <!-- Services Checklist -->
              <div class="border-t border-border pt-6" data-ps="src/components/enquire/Enquire2Content.astro:hmczc4">
                <p class="text-sm font-medium text-text mb-4" data-ps="src/components/enquire/Enquire2Content.astro:41ipnn">Additional Services</p>
                <div class="grid grid-cols-2 md:grid-cols-3 gap-y-4 gap-x-2" data-ps="src/components/enquire/Enquire2Content.astro:hmczc4">
                  {['With flight', 'With accommodation', 'Renewal of vows', 'Photography', 'Videography', 'Hair & makeup', 'Buttonholes', 'Wedding cake', 'Guest Accommodation', 'Reception', 'DJ', 'Livestream'].map(touch => (
                    <label class="flex items-center gap-2 cursor-pointer" data-ps="src/components/enquire/Enquire2Content.astro:ekm0go">
                      <input type="checkbox" name="touches[]" value={touch} class="w-4 h-4 text-accent border-gray-300 rounded focus:ring-accent" />
                      <span class="text-sm text-text-muted" data-ps="src/components/enquire/Enquire2Content.astro:lwbv7d">{touch}</span>
                    </label>
                  ))}
                </div>
              </div>
            </div>
          </details>
        </div>

        <!-- Additional Info -->
        <div class="space-y-2 pt-2" data-ps="src/components/enquire/Enquire2Content.astro:lzq0b5">
          <label for="additionalInfo" class="block text-sm font-medium text-text" data-ps="src/components/enquire/Enquire2Content.astro:ekm0gs">Additional Information</label>
          <textarea id="additionalInfo" rows="4" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-all"></textarea>
        </div>

        <div class="pt-6 space-y-6" data-ps="src/components/enquire/Enquire2Content.astro:lzq0b6">
          <button type="submit" class="w-full md:w-auto bg-[#A81E82] hover:bg-[#8e196e] text-white font-bold py-4 px-10 rounded-xl transition-all shadow-lg hover:shadow-xl hover:-translate-y-1 text-lg flex items-center justify-center gap-2" data-ps="src/components/enquire/Enquire2Content.astro:a563yp">
            Enquire Now!
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </button>

          <div class="pt-4 border-t border-border/50" data-ps="src/components/enquire/Enquire2Content.astro:ekm0fx">
            <label class="flex items-start gap-3 cursor-pointer group" data-ps="src/components/enquire/Enquire2Content.astro:bxcz6b">
              <input type="checkbox" class="mt-1 w-5 h-5 text-accent border-border rounded focus:ring-accent transition-colors cursor-pointer" />
              <div class="flex flex-col" data-ps="src/components/enquire/Enquire2Content.astro:hmczc4">
                <span class="text-sm font-medium text-text group-hover:text-primary transition-colors" data-ps="src/components/enquire/Enquire2Content.astro:lwbv7z">Yes, I'd like to receive exclusive wedding offers and inspiration via email.</span>
                <span class="text-xs text-text-muted mt-1 leading-relaxed" data-ps="src/components/enquire/Enquire2Content.astro:jwygzn">
                  By ticking this box, you agree to receive marketing communications from us. You can unsubscribe at any time. 
                  View our <a href="/privacy/" class="underline hover:text-accent" data-ps="src/components/enquire/Enquire2Content.astro:3t9hmu">Privacy Policy</a> for more details on how we protect your data.
                </span>
              </div>
            </label>
          </div>

          <p class="text-sm text-text-muted mt-4 flex items-center gap-2" data-ps="src/components/enquire/Enquire2Content.astro:gr40hb">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-green"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
            Your information is 100% secure. We will never share your details.
          </p>
        </div>
      </form>
    </div>

    <!-- Sticky Sidebar - Trust Signals -->
    <div class="lg:col-span-1" data-ps="src/components/enquire/Enquire2Content.astro:lzq0b7">
      <div class="sticky top-32 space-y-6" data-ps="src/components/enquire/Enquire2Content.astro:lzq0b8">
        
        <!-- Trustpilot -->
        <div class="bg-surface rounded-2xl p-6 border border-border" data-ps="src/components/enquire/Enquire2Content.astro:lzq0b9">
          <div class="flex items-center gap-2 mb-4" data-ps="src/components/enquire/Enquire2Content.astro:hmczcd">
            <div class="flex text-[#00b67a]" data-ps="src/components/enquire/Enquire2Content.astro:hmczcc">
              {[1, 2, 3, 4, 5].map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
          </div>
          <h3 class="font-bold text-primary mb-2" data-ps="src/components/enquire/Enquire2Content.astro:6zjzam">"Absolutely flawless experience"</h3>
          <p class="text-sm text-text-muted mb-4" data-ps="src/components/enquire/Enquire2Content.astro:gr40hc">"The Wedding Travel Company took care of everything. Our Cyprus wedding was beyond our wildest dreams!"</p>
          <div class="text-xs font-bold text-text" data-ps="src/components/enquire/Enquire2Content.astro:hmczcb">Sarah & James • Rated 4.9/5</div>
        </div>

        <!-- ATOL Protected -->
        <div class="bg-white rounded-2xl p-6 border border-border shadow-sm flex items-center gap-4" data-ps="src/components/enquire/Enquire2Content.astro:hmczca">
          <div class="w-16 h-16 bg-surface rounded-full flex items-center justify-center flex-shrink-0" data-ps="src/components/enquire/Enquire2Content.astro:hmczc9">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
          </div>
          <div data-ps="src/components/enquire/Enquire2Content.astro:hmczc8">
            <h3 class="font-bold text-primary" data-ps="src/components/enquire/Enquire2Content.astro:6zjzan">100% Financial Protection</h3>
            <p class="text-sm text-text-muted" data-ps="src/components/enquire/Enquire2Content.astro:gr40hd">ABTA & ATOL Protected</p>
          </div>
        </div>

        <!-- Award Winning -->
        <div class="bg-white rounded-2xl p-6 border border-border shadow-sm flex items-center gap-4" data-ps="src/components/enquire/Enquire2Content.astro:hmczc7">
          <div class="w-16 h-16 bg-surface rounded-full flex items-center justify-center flex-shrink-0" data-ps="src/components/enquire/Enquire2Content.astro:hmczc6">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
          </div>
          <div data-ps="src/components/enquire/Enquire2Content.astro:hmczc5">
            <h3 class="font-bold text-primary" data-ps="src/components/enquire/Enquire2Content.astro:6zjzao">Award Winning</h3>
            <p class="text-sm text-text-muted" data-ps="src/components/enquire/Enquire2Content.astro:gr40he">UK's Leading Wedding Agency</p>
          </div>
        </div>

        <!-- Contact Support -->
        <div class="bg-primary text-white rounded-2xl p-6" data-ps="src/components/enquire/Enquire2Content.astro:hmczc4">
          <h3 class="font-bold mb-2" data-ps="src/components/enquire/Enquire2Content.astro:6zjzba">Need immediate help?</h3>
          <p class="text-sm text-white/80 mb-4" data-ps="src/components/enquire/Enquire2Content.astro:gr40hf">Our wedding concierge team is ready to answer your questions.</p>
          <a href="tel:08001234567" class="flex items-center justify-center gap-2 bg-white text-primary font-bold py-3 px-4 rounded-xl hover:bg-surface transition-colors" data-ps="src/components/enquire/Enquire2Content.astro:nv1x6g">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            0800 123 4567
          </a>
        </div>

      </div>
    </div>
    
  </div>
</div>