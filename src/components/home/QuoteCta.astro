---
// Personalized Quote CTA Section
---

<section id="quote-cta" class="py-24 px-6 bg-background" data-ps="src/components/home/QuoteCta.astro:quote-cta">
  <div class="max-w-4xl mx-auto bg-surface p-12 md:p-16 rounded-[48px] shadow-sm flex flex-col md:flex-row items-center justify-between gap-12" data-ps="src/components/home/QuoteCta.astro:container">
    <div class="text-center md:text-left flex-1" data-ps="src/components/home/QuoteCta.astro:content">
      <h2 class="text-[36px] font-bold font-serif text-secondary leading-tight mb-4" data-ps="src/components/home/QuoteCta.astro:7u9192">
        Want a <br />
        <span class="text-primary italic font-normal" data-ps="src/components/home/QuoteCta.astro:vdgj3g">Personalised Quote?</span>
      </h2>
      <p class="text-muted-foreground leading-relaxed" data-ps="src/components/home/QuoteCta.astro:it9afl">
        Tell us your vision and we'll hand-pick 3–5 venues tailored to your style, guest count and budget.
      </p>
    </div>
    
    <a href="/design-your-dream-wedding" class="bg-secondary text-white rounded-full px-12 py-5 text-[14px] font-bold uppercase tracking-widest whitespace-nowrap hover:bg-secondary-hover transition-colors shadow-lg shadow-secondary/20" data-ps="src/components/home/QuoteCta.astro:button">
      Start My Wedding Plan
    </a>
  </div>
</section>
