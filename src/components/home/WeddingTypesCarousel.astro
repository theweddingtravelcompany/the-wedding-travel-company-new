---
// Wedding Types Carousel Section
import { SITE } from '@/config/site';

const weddingTypes = [
  {
    title: 'Luxury Weddings',
    href: '/wedding-type/luxury-weddings',
    image: 'https://images.pexels.com/photos/33986826/pexels-photo-33986826.jpeg?auto=compress&cs=tinysrgb&w=800',
    description: 'Opulence and elegance in every detail.'
  },
  {
    title: 'Budget Weddings',
    href: '/wedding-type/budget-weddings',
    image: 'https://images.pexels.com/photos/29500108/pexels-photo-29500108.jpeg?auto=compress&cs=tinysrgb&w=800',
    description: 'Beautiful celebrations that don\'t break the bank.'
  },
  {
    title: 'All Inclusive',
    href: '/wedding-type/all-inclusive-weddings',
    image: 'https://images.pexels.com/photos/7227901/pexels-photo-7227901.png?auto=compress&cs=tinysrgb&w=800',
    description: 'Stress-free planning with everything covered.'
  },
  {
    title: 'Boat Weddings',
    href: '/wedding-type/boat-weddings',
    image: 'https://images.pexels.com/photos/30279857/pexels-photo-30279857.jpeg?auto=compress&cs=tinysrgb&w=800',
    description: 'Say "I do" on the sparkling open waters.'
  }
];
---

<section id="wedding-types" class="pt-8 pb-12 md:pb-24 px-6 bg-white" data-ps="src/components/home/WeddingTypesCarousel.astro:section">
  <div class="max-w-7xl mx-auto" data-ps="src/components/home/WeddingTypesCarousel.astro:container">
    <div class="text-center mb-8 md:mb-16" data-ps="src/components/home/WeddingTypesCarousel.astro:header">
      <h2 class="text-[42px] font-bold font-serif text-secondary mb-4" data-ps="src/components/home/WeddingTypesCarousel.astro:title">
        Wedding <span class="text-primary italic font-normal" data-ps="src/components/home/WeddingTypesCarousel.astro:span">Types</span>
      </h2>
      <p class="text-muted-foreground max-w-2xl mx-auto" data-ps="src/components/home/WeddingTypesCarousel.astro:p">Find the perfect style for your special day.</p>
    </div>

    <div class="relative group" data-ps="src/components/home/WeddingTypesCarousel.astro:slider-wrapper">
      <!-- Left Arrow -->
      <button id="types-left" class="absolute left-2 md:-left-6 top-1/2 -translate-y-1/2 z-10 bg-white hover:bg-surface text-secondary w-10 h-10 md:w-14 md:h-14 rounded-full shadow-[0_8px_30px_rgb(0,0,0,0.12)] flex items-center justify-center opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-all duration-300 hover:scale-105" aria-label="Previous wedding type" data-ps="src/components/home/WeddingTypesCarousel.astro:btn-left">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 md:w-6 md:h-6"><path d="m15 18-6-6 6-6"/></svg>
      </button>

      <div id="types-slider" class="flex overflow-x-auto snap-x snap-mandatory gap-4 md:gap-8 pb-8 -mx-6 px-[7.5vw] md:mx-0 md:px-0 [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]" data-ps="src/components/home/WeddingTypesCarousel.astro:slider">
        {weddingTypes.map((type, __psIdx) => (
          <a href={type.href} class="w-[85vw] md:w-[calc(50%-16px)] lg:w-[calc(25%-24px)] shrink-0 snap-center md:snap-start relative rounded-2xl overflow-hidden h-[400px] md:h-[450px] group/card no-underline" data-ps={`src/components/home/WeddingTypesCarousel.astro:card-${type.title}`}>
            <img crossorigin="anonymous" src={type.image} alt={type.title} class="w-full h-full object-cover transition-transform duration-500 group-hover/card:scale-110" loading="lazy" data-ps={`src/components/home/WeddingTypesCarousel.astro:hhcbnd-${__psIdx}`} />
            <div class="absolute inset-0 bg-gradient-to-t from-secondary/80 to-transparent" data-ps="src/components/home/WeddingTypesCarousel.astro:gradient"></div>
            <div class="absolute bottom-0 left-0 p-8 w-full transition-transform duration-300 transform group-hover/card:-translate-y-4" data-ps="src/components/home/WeddingTypesCarousel.astro:content">
              <h3 class="text-2xl font-bold font-serif text-white mb-2" data-ps="src/components/home/WeddingTypesCarousel.astro:h3">{type.title}</h3>
              <p class="text-white/80 text-[10px] font-bold uppercase tracking-widest" data-ps="src/components/home/WeddingTypesCarousel.astro:desc">{type.description}</p>
              <div class="opacity-100 md:opacity-0 md:group-hover/card:opacity-100 transition-opacity duration-300 mt-6" data-ps="src/components/home/WeddingTypesCarousel.astro:cta">
                <span class="inline-block bg-primary text-white text-[10px] font-bold uppercase tracking-widest px-6 py-3 rounded-lg w-full text-center" data-ps="src/components/home/WeddingTypesCarousel.astro:span-cta">Explore {type.title}</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Right Arrow -->
      <button id="types-right" class="absolute right-2 md:-right-6 top-1/2 -translate-y-1/2 z-10 bg-white hover:bg-surface text-secondary w-10 h-10 md:w-14 md:h-14 rounded-full shadow-[0_8px_30px_rgb(0,0,0,0.12)] flex items-center justify-center opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-all duration-300 hover:scale-105" aria-label="Next wedding type" data-ps="src/components/home/WeddingTypesCarousel.astro:btn-right">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 md:w-6 md:h-6"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>

    <script>
      const typesSlider = document.getElementById('types-slider');
      const typesLeft = document.getElementById('types-left');
      const typesRight = document.getElementById('types-right');

      if (typesSlider && typesLeft && typesRight) {
        typesLeft.addEventListener('click', () => {
          const scrollAmount = window.innerWidth < 768 ? window.innerWidth * 0.85 : typesSlider.offsetWidth / 2;
          typesSlider.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
        });
        
        typesRight.addEventListener('click', () => {
          const scrollAmount = window.innerWidth < 768 ? window.innerWidth * 0.85 : typesSlider.offsetWidth / 2;
          typesSlider.scrollBy({ left: scrollAmount, behavior: 'smooth' });
        });
      }
    </script>
  </div>
</section>
