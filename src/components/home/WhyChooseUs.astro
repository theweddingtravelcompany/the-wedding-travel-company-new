        <p class="text-[14px] text-muted-foreground leading-relaxed" data-ps="src/components/home/WhyChooseUs.astro:3ula">Complete financial peace of mind for every booking.</p>
      </div>

      <!-- Feature 2 -->
      <div class="text-center group" data-ps="src/components/home/WhyChooseUs.astro:feature-2">
