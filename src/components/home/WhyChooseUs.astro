---
// Why Couples Choose Us Section
---

<section id="why-choose-us" class="py-12 md:py-24 px-6 bg-surface" data-ps="src/components/home/WhyChooseUs.astro:why-choose-us">
  <div class="max-w-7xl mx-auto" data-ps="src/components/home/WhyChooseUs.astro:container">
    <div class="text-center mb-8 md:mb-16" data-ps="src/components/home/WhyChooseUs.astro:header">
      <h2 class="text-[42px] font-bold font-serif text-secondary mb-4" data-ps="src/components/home/WhyChooseUs.astro:px62t1">
        Why Couples Choose <span class="text-primary italic font-normal" data-ps="src/components/home/WhyChooseUs.astro:pkd5pz">Us</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-10 md:gap-y-16" data-ps="src/components/home/WhyChooseUs.astro:grid">
      <!-- Feature 1 -->
      <div class="text-center group" data-ps="src/components/home/WhyChooseUs.astro:feature-1">
        <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center shadow-sm text-primary mx-auto mb-6 transition-transform group-hover:scale-110" data-ps="src/components/home/WhyChooseUs.astro:sk44gs">
