        </div>
        <h3 class="text-[20px] font-bold text-secondary mb-3" data-ps="src/components/home/WhyChooseUs.astro:y4pbkv">Exclusive Rates</h3>
        <p class="text-[14px] text-muted-foreground leading-relaxed" data-ps="src/components/home/WhyChooseUs.astro:3ulb">Direct contracts providing the best value worldwide.</p>
      </div>

      <!-- Feature 3 -->
      <div class="text-center group" data-ps="src/components/home/WhyChooseUs.astro:feature-3">
        <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center shadow-sm text-primary mx-auto mb-6 transition-transform group-hover:scale-110" data-ps="src/components/home/WhyChooseUs.astro:sk44gq">
