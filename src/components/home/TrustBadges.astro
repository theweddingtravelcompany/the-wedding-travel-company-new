      <div class="bg-accent text-white w-8 h-8 rounded-full shadow-md flex items-center justify-center hover:bg-accent-hover transition-colors" data-ps="src/components/home/TrustBadges.astro:w0xjcz">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="m15 18-6-6 6-6"/></svg>
      </div>
    </button>
    <button id="trust-nav-right" class="absolute inset-y-0 -right-5 flex items-center md:hidden z-10 transition-opacity" aria-label="Scroll right" data-ps="src/components/home/TrustBadges.astro:mobile-nav-right">
      <div class="bg-accent text-white w-8 h-8 rounded-full shadow-md flex items-center justify-center hover:bg-accent-hover transition-colors" data-ps="src/components/home/TrustBadges.astro:w0xjcy">
