<style>
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  /* Grid layout for expanded state */
  .collection-grid {
    display: grid !important;
    grid-template-columns: repeat(1, 1fr);
    gap: 2rem;
    overflow-x: visible !important;
  }

  @media (min-width: 768px) {
    .collection-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .collection-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .collection-grid .venue-card {
    min-width: 0 !important;
  }
</style>

<script>
  function initSlider() {
    const slider = document.getElementById('featured-slider');
    const prevBtn = document.getElementById('slider-prev');
    const nextBtn = document.getElementById('slider-next');

    if (!slider || !prevBtn || !nextBtn) return;

    const scrollAmount = () => {
      if (window.innerWidth >= 1024) return slider.clientWidth / 3;
      if (window.innerWidth >= 768) return slider.clientWidth / 2;
      return slider.clientWidth;
    };

    prevBtn.addEventListener('click', () => {
      slider.scrollBy({ left: -scrollAmount(), behavior: 'smooth' });
    });

    nextBtn.addEventListener('click', () => {
      slider.scrollBy({ left: scrollAmount(), behavior: 'smooth' });
    });

    // Auto-hide arrows at boundaries
    slider.addEventListener('scroll', () => {
      const isAtStart = slider.scrollLeft <= 5;
      const isAtEnd = slider.scrollLeft + slider.clientWidth >= slider.scrollWidth - 5;
      
      prevBtn.parentElement?.classList.toggle('opacity-0', isAtStart);
      prevBtn.parentElement?.classList.toggle('pointer-events-none', isAtStart);
      nextBtn.parentElement?.classList.toggle('opacity-0', isAtEnd);
      nextBtn.parentElement?.classList.toggle('pointer-events-none', isAtEnd);
    });

    // Trigger initial check
    slider.dispatchEvent(new Event('scroll'));
  }

  // Expand function for the collection page
  function initExpand() {
    if (window.location.pathname.includes('/featured-venue-collection/')) {
      const slider = document.getElementById('featured-slider');
      const expandBtn = document.getElementById('expand-featured');
      const browseLink = document.querySelector('.browse-link');
      const header = document.querySelector('.collection-header');
      const navLeft = document.querySelector('[data-ps*="nav-left"]');
      const navRight = document.querySelector('[data-ps*="nav-right"]');

      if (expandBtn) expandBtn.classList.remove('hidden');
      if (browseLink) browseLink.classList.add('hidden');
      if (header) header.classList.add('hidden');

      expandBtn?.addEventListener('click', () => {
        slider?.classList.add('collection-grid');
        expandBtn.classList.add('hidden');
        if (navLeft) navLeft.style.display = 'none';
        if (navRight) navRight.style.display = 'none';
      });
    }
  }

  // Init on load and after swaps
  initSlider();
  initExpand();
  document.addEventListener('astro:after-swap', () => {
    initSlider();
    initExpand();
  });
</script>
