      <!-- Right Arrow -->
      <button id="long-haul-right" class="absolute right-2 md:-right-6 top-1/2 -translate-y-1/2 z-10 bg-white hover:bg-surface text-secondary w-10 h-10 md:w-14 md:h-14 rounded-full shadow-[0_8px_30px_rgb(0,0,0,0.12)] flex items-center justify-center opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-all duration-300 hover:scale-105" aria-label="Next destination" data-ps="src/components/home/LongHaulParadise.astro:4mi407">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 md:w-6 md:h-6"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>

    <script>
      const lhSlider = document.getElementById('long-haul-slider');
      const lhLeft = document.getElementById('long-haul-left');
      const lhRight = document.getElementById('long-haul-right');

      if (lhSlider && lhLeft && lhRight) {
        const updateArrows = () => {
          const isAtStart = lhSlider.scrollLeft <= 10;
          const isAtEnd = Math.ceil(lhSlider.scrollLeft + lhSlider.clientWidth) >= lhSlider.scrollWidth - 10;
          
          lhLeft.style.opacity = isAtStart ? '0' : '';
          lhLeft.style.pointerEvents = isAtStart ? 'none' : '';
          
          lhRight.style.opacity = isAtEnd ? '0' : '';
          lhRight.style.pointerEvents = isAtEnd ? 'none' : '';
        };

        lhSlider.addEventListener('scroll', updateArrows, { passive: true });
        window.addEventListener('resize', updateArrows, { passive: true });
        updateArrows(); // Init state

        lhLeft.addEventListener('click', () => {
          const scrollAmount = window.innerWidth < 768 ? window.innerWidth * 0.85 : lhSlider.offsetWidth / 2;
          lhSlider.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
        });
        
        lhRight.addEventListener('click', () => {
          const scrollAmount = window.innerWidth < 768 ? window.innerWidth * 0.85 : lhSlider.offsetWidth / 2;
          lhSlider.scrollBy({ left: scrollAmount, behavior: 'smooth' });
        });
      }
    </script>
  </div>
</section>
