          <div class="absolute inset-0 bg-gradient-to-t from-secondary/80 to-transparent" data-ps="src/components/home/LongHaulParadise.astro:sdp522"></div>
          <div class="absolute bottom-0 left-0 p-8 w-full transition-transform duration-300 transform group-hover/card:-translate-y-4" data-ps="src/components/home/LongHaulParadise.astro:sdp523">
            <h3 class="text-2xl font-bold font-serif text-white mb-2" data-ps="src/components/home/LongHaulParadise.astro:8gz5ai">Caribbean</h3>
            <p class="text-white/80 text-[10px] font-bold uppercase tracking-widest" data-ps="src/components/home/LongHaulParadise.astro:sy7op7">From £6,200</p>
            <div class="opacity-100 md:opacity-0 md:group-hover/card:opacity-100 transition-opacity duration-300 mt-6" data-ps="src/components/home/LongHaulParadise.astro:sdp524">
              <span class="inline-block bg-primary text-white text-[10px] font-bold uppercase tracking-widest px-6 py-3 rounded-lg w-full text-center" data-ps="src/components/home/LongHaulParadise.astro:dlqhfv">View Venues</span>
            </div>
          </div>
        </a>

        <!-- Mauritius -->
        <a href="/destinations/mauritius" class="w-[85vw] md:w-[calc(50%-16px)] lg:w-[calc(25%-24px)] shrink-0 snap-center md:snap-start relative rounded-2xl overflow-hidden h-[400px] md:h-[450px] group/card no-underline" data-ps="src/components/home/LongHaulParadise.astro:dest-4">
          <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1589308078059-be1415eab4c3?auto=format&w=800&q=80" alt="Mauritius" class="w-full h-full object-cover transition-transform duration-500 group-hover/card:scale-110" loading="lazy" data-ps="src/components/home/LongHaulParadise.astro:ox1ksx" />
          <div class="absolute inset-0 bg-gradient-to-t from-secondary/80 to-transparent" data-ps="src/components/home/LongHaulParadise.astro:sdp525"></div>
          <div class="absolute bottom-0 left-0 p-8 w-full transition-transform duration-300 transform group-hover/card:-translate-y-4" data-ps="src/components/home/LongHaulParadise.astro:sdp526">
            <h3 class="text-2xl font-bold font-serif text-white mb-2" data-ps="src/components/home/LongHaulParadise.astro:8gz5aj">Mauritius</h3>
            <p class="text-white/80 text-[10px] font-bold uppercase tracking-widest" data-ps="src/components/home/LongHaulParadise.astro:sy7op8">From £5,900</p>
            <div class="opacity-100 md:opacity-0 md:group-hover/card:opacity-100 transition-opacity duration-300 mt-6" data-ps="src/components/home/LongHaulParadise.astro:sdp527">
              <span class="inline-block bg-primary text-white text-[10px] font-bold uppercase tracking-widest px-6 py-3 rounded-lg w-full text-center" data-ps="src/components/home/LongHaulParadise.astro:dlqhfw">View Venues</span>
