        <!-- Mexico -->
        <a href="/destinations/mexico" class="w-[85vw] md:w-[calc(50%-16px)] lg:w-[calc(25%-24px)] shrink-0 snap-center md:snap-start relative rounded-2xl overflow-hidden h-[400px] md:h-[450px] group/card no-underline" data-ps="src/components/home/LongHaulParadise.astro:yyygj7">
          <img src="https://images.pexels.com/photos/34583118/pexels-photo-34583118.jpeg?auto=format&w=800&q=80" alt="Mexico" class="w-full h-full object-cover transition-transform duration-500 group-hover/card:scale-110" loading="lazy" data-ps="src/components/home/LongHaulParadise.astro:1hjtl8" />
          <div class="absolute inset-0 bg-gradient-to-t from-secondary/80 to-transparent" data-ps="src/components/home/LongHaulParadise.astro:sdp522"></div>
          <div class="absolute bottom-0 left-0 p-8 w-full transition-transform duration-300 transform group-hover/card:-translate-y-4" data-ps="src/components/home/LongHaulParadise.astro:sdp523">
            <h3 class="text-2xl font-bold font-serif text-white mb-2" data-ps="src/components/home/LongHaulParadise.astro:ilqkf2">Mexico</h3>
            <p class="text-white/80 text-[10px] font-bold uppercase tracking-widest" data-ps="src/components/home/LongHaulParadise.astro:sy7oq7">From £2,499</p>
            <div class="opacity-100 md:opacity-0 md:group-hover/card:opacity-100 transition-opacity duration-300 mt-6" data-ps="src/components/home/LongHaulParadise.astro:sdp524">
              <span class="inline-block bg-primary text-white text-[10px] font-bold uppercase tracking-widest px-6 py-3 rounded-lg w-full text-center" data-ps="src/components/home/LongHaulParadise.astro:dlqhhj">View Venues</span>
            </div>
