---
// Testimonials Section
---

<section id="testimonials" class="py-12 md:py-24 px-6 bg-surface" data-ps="src/components/home/Testimonials.astro:testimonials">
  <div class="max-w-7xl mx-auto" data-ps="src/components/home/Testimonials.astro:container">
    <div class="text-center mb-8 md:mb-16" data-ps="src/components/home/Testimonials.astro:header">
      <h2 class="text-[42px] font-bold font-serif text-secondary mb-4" data-ps="src/components/home/Testimonials.astro:32mgq8">
        Trusted by Thousands of <span class="text-primary italic font-normal" data-ps="src/components/home/Testimonials.astro:pdgp97">Couples</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-ps="src/components/home/Testimonials.astro:grid">
      <!-- Testimonial 1 -->
      <div class="bg-white p-10 rounded-2xl shadow-sm border border-border/50 hover-lift" data-ps="src/components/home/Testimonials.astro:card-1">
        <div class="text-primary text-xl tracking-widest mb-6" data-ps="src/components/home/Testimonials.astro:jqcpxz">★★★★★</div>
        <p class="text-[16px] font-serif italic text-secondary leading-relaxed mb-8" data-ps="src/components/home/Testimonials.astro:q9h2qv">
          "The Wedding Travel Company made our Santorini wedding a dream come true. Every detail was handled with such care."
        </p>
        <div class="text-[10px] font-bold uppercase tracking-[2px] text-muted-foreground" data-ps="src/components/home/Testimonials.astro:jqcpxy">— SARAH & JAMES</div>
      </div>

      <!-- Testimonial 2 -->
      <div class="bg-white p-10 rounded-2xl shadow-sm border border-border/50 hover-lift" data-ps="src/components/home/Testimonials.astro:card-2">
        <div class="text-primary text-xl tracking-widest mb-6" data-ps="src/components/home/Testimonials.astro:jqcpxx">★★★★★</div>
        <p class="text-[16px] font-serif italic text-secondary leading-relaxed mb-8" data-ps="src/components/home/Testimonials.astro:q9h2qw">
          "Professional, reassuring, and expert-led. We felt completely supported throughout the entire planning process."
        </p>
        <div class="text-[10px] font-bold uppercase tracking-[2px] text-muted-foreground" data-ps="src/components/home/Testimonials.astro:jqcpxw">— MICHAEL & ELENA</div>
      </div>

      <!-- Testimonial 3 -->
      <div class="bg-white p-10 rounded-2xl shadow-sm border border-border/50 hover-lift" data-ps="src/components/home/Testimonials.astro:card-3">
        <div class="text-primary text-xl tracking-widest mb-6" data-ps="src/components/home/Testimonials.astro:jqcpxv">★★★★★</div>
        <p class="text-[16px] font-serif italic text-secondary leading-relaxed mb-8" data-ps="src/components/home/Testimonials.astro:q9h2qx">
          "The in-house legal team was a lifesaver. They handled all the paperwork so we could focus on our guests."
        </p>
        <div class="text-[10px] font-bold uppercase tracking-[2px] text-muted-foreground" data-ps="src/components/home/Testimonials.astro:jqcpxu">— CHLOE & TOM</div>
      </div>
    </div>
  </div>
</section>
