      <!-- Right Arrow -->
      <button id="euro-right" class="absolute right-2 md:-right-6 top-1/2 -translate-y-1/2 z-10 bg-white hover:bg-surface text-secondary w-10 h-10 md:w-14 md:h-14 rounded-full shadow-[0_8px_30px_rgb(0,0,0,0.12)] flex items-center justify-center opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-all duration-300 hover:scale-105" aria-label="Next destination" data-ps="src/components/home/EuropeanDestinations.astro:z2wf7u">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 md:w-6 md:h-6"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>

    <script>
      const euroSlider = document.getElementById('euro-slider');
      const euroLeft = document.getElementById('euro-left');
      const euroRight = document.getElementById('euro-right');

      if (euroSlider && euroLeft && euroRight) {
        const updateArrows = () => {
          const isAtStart = euroSlider.scrollLeft <= 10;
          const isAtEnd = Math.ceil(euroSlider.scrollLeft + euroSlider.clientWidth) >= euroSlider.scrollWidth - 10;
          
          euroLeft.style.opacity = isAtStart ? '0' : '';
          euroLeft.style.pointerEvents = isAtStart ? 'none' : '';
          
          euroRight.style.opacity = isAtEnd ? '0' : '';
          euroRight.style.pointerEvents = isAtEnd ? 'none' : '';
        };

        euroSlider.addEventListener('scroll', updateArrows, { passive: true });
        window.addEventListener('resize', updateArrows, { passive: true });
        updateArrows(); // Init state

        euroLeft.addEventListener('click', () => {
          const scrollAmount = window.innerWidth < 768 ? window.innerWidth * 0.85 : euroSlider.offsetWidth / 2;
          euroSlider.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
        });
        
        euroRight.addEventListener('click', () => {
          const scrollAmount = window.innerWidth < 768 ? window.innerWidth * 0.85 : euroSlider.offsetWidth / 2;
          euroSlider.scrollBy({ left: scrollAmount, behavior: 'smooth' });
        });
      }
    </script>
