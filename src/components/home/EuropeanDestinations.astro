            <h3 class="text-2xl font-bold font-serif text-white mb-2" data-ps="src/components/home/EuropeanDestinations.astro:fy54wo">Malta</h3>
            <p class="text-white/80 text-[10px] font-bold uppercase tracking-widest" data-ps="src/components/home/EuropeanDestinations.astro:h8k70f">From £2,999</p>
            <div class="opacity-100 md:opacity-0 md:group-hover/card:opacity-100 transition-opacity duration-300 mt-6" data-ps="src/components/home/EuropeanDestinations.astro:nyldx7">
              <span class="inline-block bg-primary text-white text-[10px] font-bold uppercase tracking-widest px-6 py-3 rounded-lg w-full text-center" data-ps="src/components/home/EuropeanDestinations.astro:k9691d">View Venues</span>
            </div>
          </div>
        </a>

        <!-- Turkey -->
        <a href="/destinations/turkey" class="w-[85vw] md:w-[calc(50%-16px)] lg:w-[calc(25%-24px)] shrink-0 snap-center md:snap-start relative rounded-2xl overflow-hidden h-[400px] md:h-[450px] group/card no-underline" data-ps="src/components/home/EuropeanDestinations.astro:a4mabk">
          <img src="https://images.pexels.com/photos/29205400/pexels-photo-29205400.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Turkey" class="w-full h-full object-cover transition-transform duration-500 group-hover/card:scale-110" loading="lazy" data-ps="src/components/home/EuropeanDestinations.astro:yzjk0u" />
          <div class="absolute inset-0 bg-gradient-to-t from-secondary/80 to-transparent" data-ps="src/components/home/EuropeanDestinations.astro:nyldx6"></div>
          <div class="absolute bottom-0 left-0 p-8 w-full transition-transform duration-300 transform group-hover/card:-translate-y-4" data-ps="src/components/home/EuropeanDestinations.astro:nyldx5">
            <h3 class="text-2xl font-bold font-serif text-white mb-2" data-ps="src/components/home/EuropeanDestinations.astro:fy54wp">Turkey</h3>
            <p class="text-white/80 text-[10px] font-bold uppercase tracking-widest" data-ps="src/components/home/EuropeanDestinations.astro:h8k70e">From £3,100</p>
