---
// Navigation - Two-row layout matching screenshot
import { SITE } from '@/config/site';
---

<header id="navbar" class="sticky top-0 z-50 bg-white text-[var(--text)] border-b border-stone-100 transition-all duration-300" data-ps="src/components/Navigation.astro:dt8k86">
  <!-- Top Bar -->
  <div class="bg-[var(--primary)] text-white py-2 px-6 text-[10px] uppercase tracking-[0.2em] font-semibold text-center md:text-left" data-ps="src/components/Navigation.astro:topbar">
    <div class="max-w-7xl mx-auto flex justify-center md:justify-between items-center" data-ps="src/components/Navigation.astro:gqvsdc">
      <span class="hidden md:inline" data-ps="src/components/Navigation.astro:i2om6d">Trustpilot ★★★★★ 4.9/5</span>
      <div class="flex items-center gap-2 md:gap-4 w-full md:w-auto px-4 md:px-0" data-ps="src/components/Navigation.astro:gqvsdd">
        <a href="tel:08000911137" class="hidden md:inline hover:text-white/80 transition-colors" data-ps="src/components/Navigation.astro:7vkjsb">Call Us: 0800 0911 137</a>
        <div class="flex md:hidden items-center gap-2 w-full" data-ps="src/components/Navigation.astro:m-btns-wrapper">
          <a href="tel:08000911137" class="flex-1 inline-flex items-center justify-center py-1.5 border border-white/30 bg-white/10 hover:bg-white/20 text-white transition-all rounded-[2px]" aria-label="Call Us" data-ps="src/components/Navigation.astro:m-call-top">
            <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span class="text-[9px] font-bold uppercase tracking-[0.2em]" data-ps="src/components/Navigation.astro:i2om6i">Call Now</span>
          </a>
          <a href="/enquire2" class="flex-1 inline-flex items-center justify-center py-1.5 bg-[#A81E82] hover:bg-[#8e196e] text-white font-bold text-[9px] uppercase tracking-[0.2em] transition-all rounded-[2px]" data-ps="src/components/Navigation.astro:m-enquire-top">ENQUIRE NOW</a>
        </div>
      </div>
    </div>
  </div>

  <nav class="py-5 md:py-4" data-ps="src/components/Navigation.astro:m59h3b">
    <div class="max-w-7xl mx-auto px-6 flex justify-between items-center" data-ps="src/components/Navigation.astro:gqvsdb">
      <!-- Logo Section -->
      <a href="/" class="flex items-center gap-3 group no-underline" data-ps="src/components/Navigation.astro:kd8n5y">
        <img 
          src="https://cdn.pagesmith.app/b45770a6/images/wedding-travel-co-full-logo-full-colour-rgb.svg" 
          alt="The Wedding Travel Company" 
          class="h-10 md:h-11 w-auto object-contain"
          loading="eager"
          fetchpriority="high" data-ps="src/components/Navigation.astro:d4d69v" />
      </a>

      <!-- Desktop Links -->
      <div class="flex items-center gap-6" data-ps="src/components/Navigation.astro:gqvsdc">
        <div class="hidden lg:flex gap-8 items-center" data-ps="src/components/Navigation.astro:gqvsdd">
          <div class="relative group" data-ps="src/components/Navigation.astro:gqvsdb">
            <button class="text-[#333333] font-bold text-[11px] uppercase tracking-widest no-underline hover:text-[#A81E82] transition-colors flex items-center gap-1.5" data-ps="src/components/Navigation.astro:dest-btn">
              Destinations
              <svg class="w-3 h-3 text-stone-600 group-hover:text-[#A81E82] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </button>
            <div class="absolute left-0 top-full pt-4 hidden group-hover:block" data-ps="src/components/Navigation.astro:gqvsdc">
              <div class="bg-white shadow-2xl border border-stone-100 py-4 min-w-[220px] rounded-lg overflow-hidden" data-ps="src/components/Navigation.astro:gqvsdd">
                <a href="/destinations/all-destinations" class="block px-6 py-3 text-[10px] font-bold uppercase tracking-widest text-[#333333] hover:bg-stone-50 hover:text-[#A81E82] transition-all" data-ps="src/components/Navigation.astro:kd8n5x">All Destinations</a>
                <a href="/destinations/cyprus" class="block px-6 py-3 text-[10px] font-bold uppercase tracking-widest text-[#333333] hover:bg-stone-50 hover:text-[#A81E82] transition-all" data-ps="src/components/Navigation.astro:kd8n5w">Weddings in Cyprus</a>
                <a href="/destinations/greece" class="block px-6 py-3 text-[10px] font-bold uppercase tracking-widest text-[#333333] hover:bg-stone-50 hover:text-[#A81E82] transition-all" data-ps="src/components/Navigation.astro:kd8n5v">Weddings in Greece</a>
                <a href="/design-your-dream-wedding#browse" class="block px-6 py-3 text-[10px] font-bold uppercase tracking-widest text-[#333333] hover:bg-stone-50 hover:text-[#A81E82] transition-all" data-ps="src/components/Navigation.astro:kd8n5u">Weddings in Italy</a>
              </div>
            </div>
          </div>
          <div class="relative group" data-ps="src/components/Navigation.astro:types-dropdown">
            <a href="/wedding-type/" class="text-[#333333] font-bold text-[11px] uppercase tracking-widest no-underline hover:text-[#A81E82] transition-colors flex items-center gap-1.5" data-ps="src/components/Navigation.astro:types-btn">
              Wedding Types
              <svg class="w-3 h-3 text-stone-600 group-hover:text-[#A81E82] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </a>
            <div class="absolute left-0 top-full pt-4 hidden group-hover:block" data-ps="src/components/Navigation.astro:gqvsdc">
              <div class="bg-white shadow-2xl border border-stone-100 py-4 min-w-[220px] rounded-lg overflow-hidden" data-ps="src/components/Navigation.astro:gqvsdd">
                <a href="/wedding-type/" class="block px-6 py-3 text-[10px] font-bold uppercase tracking-widest text-[#333333] hover:bg-stone-50 hover:text-[#A81E82] transition-all" data-ps="src/components/Navigation.astro:type-all-types">All Wedding Types</a>
                <a href="/wedding-type/luxury-weddings/" class="block px-6 py-3 text-[10px] font-bold uppercase tracking-widest text-[#333333] hover:bg-stone-50 hover:text-[#A81E82] transition-all" data-ps="src/components/Navigation.astro:type-lux">Luxury Weddings</a>
                <a href="/wedding-type/budget-weddings/" class="block px-6 py-3 text-[10px] font-bold uppercase tracking-widest text-[#333333] hover:bg-stone-50 hover:text-[#A81E82] transition-all" data-ps="src/components/Navigation.astro:type-bud">Budget Weddings</a>
                <a href="/wedding-type/all-inclusive-weddings/" class="block px-6 py-3 text-[10px] font-bold uppercase tracking-widest text-[#333333] hover:bg-stone-50 hover:text-[#A81E82] transition-all" data-ps="src/components/Navigation.astro:type-all">All Inclusive Weddings</a>
                <a href="/wedding-type/boat-weddings/" class="block px-6 py-3 text-[10px] font-bold uppercase tracking-widest text-[#333333] hover:bg-stone-50 hover:text-[#A81E82] transition-all" data-ps="src/components/Navigation.astro:type-boat">Boat Weddings</a>
              </div>
            </div>
          </div>
          <a href="/design-your-dream-wedding" class="text-[#333333] font-bold text-[11px] uppercase tracking-widest no-underline hover:text-[#A81E82] transition-colors" data-ps="src/components/Navigation.astro:7vkjse">Design Your Wedding</a>
          <a href="/testimonials" class="text-[#333333] font-bold text-[11px] uppercase tracking-widest no-underline hover:text-[#A81E82] transition-colors" data-ps="src/components/Navigation.astro:7vkjse-test">Testimonials</a>
          <a href="/wishlist" class="relative flex items-center gap-2 text-[#333333] hover:text-[#A81E82] transition-colors group" aria-label="View your shortlist" data-ps="src/components/Navigation.astro:kd8n5v">
            <div class="relative" data-ps="src/components/Navigation.astro:gqvsdd">
              <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
              <span id="wishlist-badge-desktop" class="absolute -top-2 -right-2 bg-fuchsia-800 text-stone-50 text-[9px] font-bold w-4 h-4 rounded-full flex items-center justify-center opacity-0 transition-opacity" data-ps="src/components/Navigation.astro:i2om6e">0</span>
            </div>
            <span class="text-[11px] font-bold uppercase tracking-widest hidden md:inline" data-ps="src/components/Navigation.astro:i2om6f">Wishlist</span>
          </a>
          <a href="/enquire2" class="inline-block px-6 py-3 bg-[#A81E82] text-[#FFFFFF] font-bold text-[10px] uppercase tracking-[0.2em] hover:bg-[#8e196e] transition-all duration-300 rounded-[4px]" data-ps="src/components/Navigation.astro:7vkjsf">Enquire Now</a>
        </div>

        <button
          id="mobile-menu-button"
          type="button"
          class="lg:hidden p-2 text-[var(--primary)]"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
         data-ps="src/components/Navigation.astro:5ds1">
          <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile Menu Overlay -->
  <div 
    id="mobile-menu-overlay" 
    class="fixed inset-0 bg-[#1F2A44]/40 backdrop-blur-sm z-40 opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"
    data-ps="src/components/Navigation.astro:overlay">
  </div>

  <!-- Mobile Menu Drawer -->
  <div
    id="mobile-menu"
    class="fixed top-0 right-0 bottom-0 w-[85%] max-w-[400px] bg-white z-50 translate-x-full transition-transform duration-300 ease-in-out shadow-[-20px_0_40px_rgba(0,0,0,0.1)] lg:hidden flex flex-col"
    role="navigation"
   data-ps="src/components/Navigation.astro:gqvsde">
    
    <!-- Mobile Menu Header -->
    <div class="flex items-center justify-between px-6 py-6 border-b border-stone-100" data-ps="src/components/Navigation.astro:m-header">
      <a href="/" class="flex items-center no-underline" data-ps="src/components/Navigation.astro:m-logo">
        <img 
          src="https://cdn.pagesmith.app/b45770a6/images/wedding-travel-co-full-logo-full-colour-rgb.svg" 
          alt="The Wedding Travel Company" 
          class="h-8 w-auto object-contain"
          loading="lazy" data-ps="src/components/Navigation.astro:m-logo-img" />
      </a>
      <button 
        id="mobile-menu-close" 
        class="p-2 text-[#1F2A44] hover:text-[#A81E82] transition-colors"
        aria-label="Close menu"
        data-ps="src/components/Navigation.astro:m-close">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile Menu Scrollable Content -->
    <div class="flex-1 overflow-y-auto px-6 py-8" data-ps="src/components/Navigation.astro:m-scroll">
      
      <!-- Primary Section -->
      <div class="mb-10" data-ps="src/components/Navigation.astro:m-primary">
        <h3 class="text-[#999999] text-[10px] font-bold uppercase tracking-[0.2em] mb-4 flex items-center gap-3" data-ps="src/components/Navigation.astro:m-h-primary">
          Primary
          <span class="flex-1 h-px bg-[#E5E5E5]" data-ps="src/components/Navigation.astro:i2om6g"></span>
        </h3>
        
        <div class="space-y-1" data-ps="src/components/Navigation.astro:m-links-primary">
          <!-- Accordion: Destinations -->
          <div class="mobile-accordion group" data-ps="src/components/Navigation.astro:m-acc-dest">
            <button class="mobile-accordion-trigger w-full flex items-center justify-between py-4 text-[#1F2A44] font-bold text-sm uppercase tracking-wider group-hover:text-[#A81E82] transition-colors" data-ps="src/components/Navigation.astro:m-dest-btn">
              Destinations
              <svg class="w-4 h-4 text-stone-600 group-hover:text-[#A81E82] transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </button>
            <div class="mobile-accordion-content hidden space-y-3 pb-4 pl-4" data-ps="src/components/Navigation.astro:m-dest-links">
              <a href="/destinations/all-destinations" class="block text-[#1F2A44] text-[13px] font-medium py-1 hover:text-[#A81E82]" data-ps="src/components/Navigation.astro:m-dest-all">All Destinations</a>
              <a href="/destinations/cyprus" class="block text-[#1F2A44] text-[13px] font-medium py-1 hover:text-[#A81E82]" data-ps="src/components/Navigation.astro:m-dest-cyp">Weddings in Cyprus</a>
              <a href="/destinations/greece" class="block text-[#1F2A44] text-[13px] font-medium py-1 hover:text-[#A81E82]" data-ps="src/components/Navigation.astro:m-dest-gre">Weddings in Greece</a>
              <a href="/design-your-dream-wedding#browse" class="block text-[#1F2A44] text-[13px] font-medium py-1 hover:text-[#A81E82]" data-ps="src/components/Navigation.astro:m-dest-ita">Weddings in Italy</a>
            </div>
          </div>

          <!-- Accordion: Wedding Types -->
          <div class="mobile-accordion group" data-ps="src/components/Navigation.astro:m-acc-types">
            <button class="mobile-accordion-trigger w-full flex items-center justify-between py-4 text-[#1F2A44] font-bold text-sm uppercase tracking-wider group-hover:text-[#A81E82] transition-colors" data-ps="src/components/Navigation.astro:m-types-btn">
              Wedding Types
              <svg class="w-4 h-4 text-stone-600 group-hover:text-[#A81E82] transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </button>
            <div class="mobile-accordion-content hidden space-y-3 pb-4 pl-4" data-ps="src/components/Navigation.astro:m-types-links">
              <a href="/wedding-type/" class="block text-[#1F2A44] text-[13px] font-bold py-1 hover:text-[#A81E82]" data-ps="src/components/Navigation.astro:m-t-all-types">All Wedding Types</a>
              <a href="/wedding-type/luxury-weddings/" class="block text-[#1F2A44] text-[13px] font-medium py-1 hover:text-[#A81E82]" data-ps="src/components/Navigation.astro:m-t-lux">Luxury Weddings</a>
              <a href="/wedding-type/budget-weddings/" class="block text-[#1F2A44] text-[13px] font-medium py-1 hover:text-[#A81E82]" data-ps="src/components/Navigation.astro:m-t-bud">Budget Weddings</a>
              <a href="/wedding-type/all-inclusive-weddings/" class="block text-[#1F2A44] text-[13px] font-medium py-1 hover:text-[#A81E82]" data-ps="src/components/Navigation.astro:m-t-all">All Inclusive Weddings</a>
              <a href="/wedding-type/boat-weddings/" class="block text-[#1F2A44] text-[13px] font-medium py-1 hover:text-[#A81E82]" data-ps="src/components/Navigation.astro:m-t-boat">Boat Weddings</a>
            </div>
          </div>

          <a href="/design-your-dream-wedding" class="block py-4 text-[#1F2A44] font-bold text-sm uppercase tracking-wider hover:text-[#A81E82] transition-colors" data-ps="src/components/Navigation.astro:m-link-design">Design Your Wedding</a>
        </div>
      </div>

      <!-- Secondary Section -->
      <div class="mb-32" data-ps="src/components/Navigation.astro:m-secondary">
        <h3 class="text-[#999999] text-[10px] font-bold uppercase tracking-[0.2em] mb-4 flex items-center gap-3" data-ps="src/components/Navigation.astro:m-h-sec">
          Secondary
          <span class="flex-1 h-px bg-[#E5E5E5]" data-ps="src/components/Navigation.astro:i2om6h"></span>
        </h3>
        <div class="space-y-1" data-ps="src/components/Navigation.astro:m-links-sec">
          <a href="/wishlist" class="flex items-center justify-between py-4 group" data-ps="src/components/Navigation.astro:m-wishlist">
            <span class="text-[#1F2A44] font-bold text-sm uppercase tracking-wider group-hover:text-[#A81E82] transition-colors flex items-center gap-2" data-ps="src/components/Navigation.astro:i2om6i">
              <div class="relative" data-ps="src/components/Navigation.astro:gqvsde">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
                <span id="wishlist-badge-mobile" class="absolute -top-2 -right-2 bg-fuchsia-800 text-stone-50 text-[8px] font-bold w-3.5 h-3.5 rounded-full flex items-center justify-center opacity-0 transition-opacity" data-ps="src/components/Navigation.astro:i2om6g">0</span>
              </div>
              Wishlist
            </span>
            <svg class="w-4 h-4 text-stone-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
          </a>
          <a href="/testimonials" class="block py-4 text-[#1F2A44] font-bold text-sm uppercase tracking-wider hover:text-[#A81E82] transition-colors" data-ps="src/components/Navigation.astro:m-link-test">Testimonials</a>
          <a href="/blog" class="block py-4 text-[#1F2A44] font-bold text-sm uppercase tracking-wider hover:text-[#A81E82] transition-colors" data-ps="src/components/Navigation.astro:m-link-blog">Blog</a>
          <a href="/enquire2" class="block py-4 text-[#1F2A44] font-bold text-sm uppercase tracking-wider hover:text-[#A81E82] transition-colors" data-ps="src/components/Navigation.astro:m-link-cont">Contact</a>
          <a href="/careers" class="block py-4 text-[#1F2A44] font-bold text-sm uppercase tracking-wider hover:text-[#A81E82] transition-colors" data-ps="src/components/Navigation.astro:m-link-careers">Careers</a>
        </div>
      </div>
    </div>

    <!-- Mobile Menu Footer CTA -->
    <div class="p-6 bg-white border-t border-stone-100 mt-auto" data-ps="src/components/Navigation.astro:m-footer">
      <a href="/enquire2" class="flex items-center justify-center w-full px-8 py-3.5 bg-[#A81E82] text-white font-bold text-[13px] uppercase tracking-[0.2em] rounded-md shadow-lg shadow-[#A81E82]/20 hover:bg-[#8e196e] transition-all active:scale-[0.98]" data-ps="src/components/Navigation.astro:m-enquire-btn">
        Enquire Now
      </a>
    </div>
  </div>
</header>

<script is:inline>
  // Wishlist Counter Logic
  function updateWishlistBadges() {
    try {
      const saved = localStorage.getItem('wtc_wishlist_v1');
      if (saved) {
        const { state } = JSON.parse(saved);
        const count = state?.items?.length || 0;
        
        const badges = [
          document.getElementById('wishlist-badge-desktop'),
          document.getElementById('wishlist-badge-mobile')
        ];

        badges.forEach(badge => {
          if (badge) {
            badge.textContent = count;
            badge.style.opacity = count > 0 ? '1' : '0';
          }
        });
      }
    } catch (e) {
      console.error('Error updating wishlist badges:', e);
    }
  }

  // Initial update and event listener
  updateWishlistBadges();
  window.addEventListener('wishlist:updated', updateWishlistBadges);
  // Also listen for storage changes (for multiple tabs)
  window.addEventListener('storage', (e) => {
    if (e.key === 'wtc_wishlist_v1') updateWishlistBadges();
  });

  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenuClose = document.getElementById('mobile-menu-close');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileOverlay = document.getElementById('mobile-menu-overlay');
  const accordionTriggers = document.querySelectorAll('.mobile-accordion-trigger');

  function openMenu() {
    mobileMenu?.classList.remove('translate-x-full');
    mobileOverlay?.classList.remove('opacity-0', 'pointer-events-none');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    mobileMenu?.classList.add('translate-x-full');
    mobileOverlay?.classList.add('opacity-0', 'pointer-events-none');
    document.body.style.overflow = '';
  }

  mobileMenuButton?.addEventListener('click', openMenu);
  mobileMenuClose?.addEventListener('click', closeMenu);
  mobileOverlay?.addEventListener('click', closeMenu);

  // Accordion Logic
  accordionTriggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      const content = trigger.nextElementSibling;
      const icon = trigger.querySelector('svg');
      const isOpen = !content.classList.contains('hidden');
      
      // Close all other accordions
      accordionTriggers.forEach(otherTrigger => {
        if (otherTrigger !== trigger) {
          otherTrigger.nextElementSibling.classList.add('hidden');
          otherTrigger.querySelector('svg').classList.remove('rotate-180');
        }
      });

      // Toggle current accordion
      if (isOpen) {
        content.classList.add('hidden');
        icon.classList.remove('rotate-180');
      } else {
        content.classList.remove('hidden');
        icon.classList.add('rotate-180');
      }
    });
  });
</script>