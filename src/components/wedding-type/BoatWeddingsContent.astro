    <div class="mb-10 md:mb-16" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:1sfwrz">
      <h2 class="text-[28px] font-bold font-serif text-secondary mb-8 text-center" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:iy9hke">Other Wedding Types</h2>
