---
// Boat Weddings Content
import { WishlistButton } from '@/components/wishlist/WishlistButton';
---

<section class="py-12 md:py-24 px-4 md:px-6 bg-background" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:e7j1kx">
  <div class="max-w-7xl mx-auto" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:fjett4">
    <!-- Intro -->
    <div class="text-center mb-10 md:mb-16" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:fjett3">
      <h2 class="text-[42px] font-bold font-serif text-secondary mb-6" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:iy9hkg">Exchange Vows at Sea: Boat Weddings</h2>
      <p class="text-muted-foreground text-lg max-w-3xl mx-auto leading-relaxed mb-8" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:z90hzg">
        There's no backdrop quite like the open ocean. Our boat weddings offer a truly unique and memorable way to celebrate your marriage, combining the luxury of a private charter with the natural beauty of the Mediterranean coastline.
      </p>
      <p class="text-muted-foreground max-w-3xl mx-auto leading-relaxed mb-8" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:z90hzf">
        From sleek modern yachts to traditional sailing schooners, we have a vessel to match every style and group size. Imagine cruising into the sunset as you enjoy your first meal as a married couple, surrounded by 360-degree ocean views.
      </p>
      <div class="flex flex-wrap justify-center gap-4 text-[10px] font-bold uppercase tracking-widest" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:fjett2">
        <span class="flex items-center gap-2 text-secondary" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:5z62cv"><svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Exclusive private boat hire</span>
        <span class="flex items-center gap-2 text-secondary" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:5z62cu"><svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Onboard catering & bar</span>
        <span class="flex items-center gap-2 text-secondary" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:5z62ct"><svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Spectacular sunset photography</span>
        <span class="flex items-center gap-2 text-secondary" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:5z62cs"><svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Experienced maritime crew</span>
      </div>
    </div>

    <!-- Venues Grid -->
    <div class="mb-10 md:mb-16" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:fjett1">
