              <a href="/venues/st-raphael-resort" class="bg-secondary text-white text-center py-3 rounded-lg text-sm font-bold hover:bg-secondary-hover transition-colors" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:jzviya">View Vessel</a>
