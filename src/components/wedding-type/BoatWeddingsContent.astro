              <div class="bg-white px-2 py-1 rounded-full flex items-center gap-1 shadow-sm border border-border/50" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:1sfws1">
                <div class="flex items-center gap-0.5" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:1sfws2">
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:1sfws3"></div>
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:1sfws4"></div>
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:1sfws5"></div>
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:1sfws6"></div>
