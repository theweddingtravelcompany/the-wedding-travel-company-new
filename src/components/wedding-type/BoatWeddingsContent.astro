                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:fjetra"></div>
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:fjetqo"></div>
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:fjetqn"></div>
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:fjetqm"></div>
