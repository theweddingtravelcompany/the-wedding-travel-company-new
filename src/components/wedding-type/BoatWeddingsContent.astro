            <div class="absolute top-4 left-4 bg-secondary/90 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest text-white" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:fjetqn">Unique Pick</div>
            <div class="absolute top-4 right-4" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:fjetqm">
