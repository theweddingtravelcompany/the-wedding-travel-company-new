              <span class="text-2xl font-bold text-secondary" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:5z62by">£2,999</span>
              <span class="text-muted-foreground text-sm" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:5z62bx">Based on 30 guests</span>
            </div>
            <div class="grid grid-cols-2 gap-4" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:fjetrb">
              <a href="/venues/st-raphael-resort/" class="bg-secondary text-white text-center py-3 rounded-lg text-sm font-bold hover:bg-secondary-hover transition-colors" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:jzviy8">View Vessel</a>
              <a href="/enquire2" class="text-primary text-[10px] font-bold uppercase tracking-widest text-center py-3 hover:opacity-80 transition-opacity" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:jzviy7">Enquire Now</a>
            </div>
          </div>
        </div>

        <!-- Venue 3 -->
        <div class="bg-white border border-border rounded-xl overflow-hidden shadow-sm hover-lift" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:fjetra">
          <div class="relative aspect-video overflow-hidden" data-ps="src/components/wedding-type/BoatWeddingsContent.astro:fjetqo">
