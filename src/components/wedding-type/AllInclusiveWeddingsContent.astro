            </div>
            <div class="grid grid-cols-2 gap-4" data-ps="src/components/wedding-type/AllInclusiveWeddingsContent.astro:5yxoaa">
              <a href="/venues/st-raphael-resort/" class="bg-secondary text-white text-center py-3 rounded-lg text-sm font-bold hover:bg-secondary-hover transition-colors" data-ps="src/components/wedding-type/AllInclusiveWeddingsContent.astro:5k7vd1">View Package</a>
