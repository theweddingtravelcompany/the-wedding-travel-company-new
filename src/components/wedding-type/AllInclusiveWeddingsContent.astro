              <div class="bg-white px-2 py-1 rounded-full flex items-center gap-1 shadow-sm border border-border/50" data-ps="src/components/wedding-type/AllInclusiveWeddingsContent.astro:mpxwd9">
                <div class="flex items-center gap-0.5" data-ps="src/components/wedding-type/AllInclusiveWeddingsContent.astro:mpxwda">
