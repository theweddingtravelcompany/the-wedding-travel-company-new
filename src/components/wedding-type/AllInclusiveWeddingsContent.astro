                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/AllInclusiveWeddingsContent.astro:mpxwdf"></div>
                </div>
                <span class="text-secondary font-bold text-[10px]" data-ps="src/components/wedding-type/AllInclusiveWeddingsContent.astro:qn5yjo">5.0</span>
