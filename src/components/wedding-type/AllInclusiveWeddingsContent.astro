---
// All Inclusive Weddings Content
import { WishlistButton } from '@/components/wishlist/WishlistButton';
---

<section class="py-12 md:py-24 px-4 md:px-6 bg-background" data-ps="src/components/wedding-type/AllInclusiveWeddingsContent.astro:ki81f8">
  <div class="max-w-7xl mx-auto" data-ps="src/components/wedding-type/AllInclusiveWeddingsContent.astro:5yxoc3">
    <!-- Intro -->
    <div class="text-center mb-10 md:mb-16" data-ps="src/components/wedding-type/AllInclusiveWeddingsContent.astro:5yxoc2">
      <h2 class="text-[42px] font-bold font-serif text-secondary mb-6" data-ps="src/components/wedding-type/AllInclusiveWeddingsContent.astro:2cfhtx">Stress-Free All Inclusive Weddings</h2>
      <p class="text-muted-foreground text-lg max-w-3xl mx-auto leading-relaxed mb-8" data-ps="src/components/wedding-type/AllInclusiveWeddingsContent.astro:rwsdjr">
        Our all-inclusive wedding packages are designed for couples who want to enjoy the excitement of planning without the stress of managing multiple vendors and unpredictable costs. By bundling everything together, we provide a seamless experience and exceptional value.
      </p>
      <p class="text-muted-foreground max-w-3xl mx-auto leading-relaxed mb-8" data-ps="src/components/wedding-type/AllInclusiveWeddingsContent.astro:rwsdjq">
        From the flowers for your ceremony to the late-night dancing at your reception, our comprehensive packages cover it all. You'll know exactly what your wedding will cost from day one, allowing you to focus on the romance and joy of your upcoming celebration.
      </p>
      <div class="flex flex-wrap justify-center gap-4 text-[10px] font-bold uppercase tracking-widest" data-ps="src/components/wedding-type/AllInclusiveWeddingsContent.astro:5yxoc1">
        <span class="flex items-center gap-2 text-secondary" data-ps="src/components/wedding-type/AllInclusiveWeddingsContent.astro:qn5ydi"><svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Complete vendor coordination</span>
        <span class="flex items-center gap-2 text-secondary" data-ps="src/components/wedding-type/AllInclusiveWeddingsContent.astro:qn5ydj"><svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Fixed-price packages</span>
        <span class="flex items-center gap-2 text-secondary" data-ps="src/components/wedding-type/AllInclusiveWeddingsContent.astro:qn5ydk"><svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Catering & open bar options</span>
        <span class="flex items-center gap-2 text-secondary" data-ps="src/components/wedding-type/AllInclusiveWeddingsContent.astro:qn5ydl"><svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Expert planning guidance</span>
      </div>
    </div>

    <!-- Venues Grid -->
    <div class="mb-10 md:mb-16" data-ps="src/components/wedding-type/AllInclusiveWeddingsContent.astro:5yxoc0">
