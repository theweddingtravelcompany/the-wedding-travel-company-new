              <div class="bg-white px-2 py-1 rounded-full flex items-center gap-1 shadow-sm border border-border/50" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:jxnau7">
                <div class="flex items-center gap-0.5" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:jxnau8">
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:jxnau9"></div>
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:jxnaua"></div>
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:jxnaub"></div>
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:jxnauc"></div>
