            </div>
          </div>
        </div>

        <!-- Venue 3 -->
        <div class="bg-white border border-border rounded-xl overflow-hidden shadow-sm hover-lift" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5pv">
          <div class="relative aspect-video overflow-hidden" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5p9">
            <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&w=800&q=80" alt="Private Mountain Villa" class="w-full h-full object-cover" loading="lazy" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:nt7a3a" />
            <div class="absolute top-4 left-4 bg-primary/90 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest text-white" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5p8">Luxury Pick</div>
            <div class="absolute top-4 right-4" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5p7">
              <WishlistButton 
