              <a href="/enquire2" class="text-primary text-[10px] font-bold uppercase tracking-widest text-center py-3 hover:opacity-80 transition-opacity" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:gq47lp">Request Quote</a>
            </div>
