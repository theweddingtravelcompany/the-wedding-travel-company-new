---
// Luxury Weddings Content
import { WishlistButton } from '@/components/wishlist/WishlistButton';
---

<section class="py-12 md:py-24 px-4 md:px-6 bg-background" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:ttspvy">
  <div class="max-w-7xl mx-auto" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5rp">
    <!-- Intro -->
    <div class="text-center mb-10 md:mb-16" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5ro">
      <h2 class="text-[42px] font-bold font-serif text-secondary mb-6" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:bf583n">The Art of Luxury Weddings</h2>
      <p class="text-muted-foreground text-lg max-w-3xl mx-auto leading-relaxed mb-8" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:gtbcgp">
        For couples seeking the extraordinary, our luxury weddings offer a level of refinement and sophistication that is truly world-class. We partner with the most prestigious hotels, private estates, and historic landmarks across Europe and beyond to create celebrations that surpass every expectation.
      </p>
      <p class="text-muted-foreground max-w-3xl mx-auto leading-relaxed mb-8" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:gtbcgo">
        From the moment you begin your journey with us, you'll have access to our most senior planners, who specialise in orchestrating high-end events. Whether it's a cliffside ceremony in Santorini or a grand Venetian gala, we ensure every detail reflects your personal style.
      </p>
      <div class="flex flex-wrap justify-center gap-4 text-[10px] font-bold uppercase tracking-widest" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5rn">
        <span class="flex items-center gap-2 text-secondary" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:5ng2gp"><svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Exclusive-use luxury venues</span>
        <span class="flex items-center gap-2 text-secondary" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:5ng2go"><svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Michelin-star quality catering</span>
        <span class="flex items-center gap-2 text-secondary" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:5ng2gn"><svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Bespoke floral & event design</span>
        <span class="flex items-center gap-2 text-secondary" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:5ng2gm"><svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Private concierge for you & guests</span>
      </div>
    </div>

    <!-- Venues Grid -->
    <div class="mb-10 md:mb-16" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5rm">
      <div class="flex justify-between items-center mb-8" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5rl">
        <h3 class="text-[28px] font-bold font-serif text-secondary" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:399p4r">Luxury Venues</h3>
        <button class="text-sm text-muted-foreground hover:text-primary transition-colors" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:oz0w79">× Close</button>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5qz">
        <!-- Venue 1 -->
        <div class="bg-white border border-border rounded-xl overflow-hidden shadow-sm hover-lift" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5qy">
          <div class="relative aspect-video overflow-hidden" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5qx">
            <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&w=800&q=80" alt="Luxury Beachfront Estate" class="w-full h-full object-cover" loading="lazy" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:nt7a3x" />
            <div class="absolute top-4 left-4 bg-primary/90 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest text-white" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5qw">Luxury Pick</div>
            <div class="absolute top-4 right-4" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5qv">
              <WishlistButton 
                client:load 
                venue={{
                  id: "st-raphael-resort",
                  name: "Luxury Beachfront Estate",
                  location: "Cyprus",
                  image: "https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&w=800&q=80"
                }} 
                iconOnly={true}
              />
            </div>
          </div>
          <div class="p-6 md:p-8" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5qu">
            <div class="flex items-center gap-2 mb-3" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5qt">
              <div class="bg-white px-2 py-1 rounded-full flex items-center gap-1 shadow-sm border border-border/50" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5pw">
                <div class="flex items-center gap-0.5" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5pv">
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5p9"></div>
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5p8"></div>
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5p7"></div>
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5p6"></div>
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5p5"></div>
                </div>
                <span class="text-secondary font-bold text-[10px]" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:5ng2an">5.0</span>
              </div>
            </div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground mb-1" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:gtbcgn">Cyprus • Premium Resort</p>
            <h3 class="text-xl font-bold font-serif text-secondary mb-3" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:399p4q">Luxury Beachfront Estate</h3>
            <p class="text-sm text-muted-foreground mb-4" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:gtbcgm">An exclusive beachfront estate offering unparalleled luxury, private pool access, and bespoke wedding services for elite celebrations.</p>
            <div class="flex items-baseline gap-2 mb-6" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5qs">
              <span class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:5ng2fy">Starting From</span>
              <span class="text-2xl font-bold text-secondary" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:5ng2fx">£8,999</span>
