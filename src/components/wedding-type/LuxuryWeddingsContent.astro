            <div class="grid grid-cols-2 gap-4" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5qq">
              <a href="/venues/st-raphael-resort" class="bg-secondary text-white text-center py-3 rounded-lg text-sm font-bold hover:bg-secondary-hover transition-colors" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:gq47lu">Explore Venue</a>
              <a href="/enquire2" class="text-primary text-[10px] font-bold uppercase tracking-widest text-center py-3 hover:opacity-80 transition-opacity" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:gq47lt">Request Quote</a>
            </div>
