          <div class="relative aspect-video overflow-hidden" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5q3">
            <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?auto=format&w=800&q=80" alt="Five-Star Palace Hotel" class="w-full h-full object-cover" loading="lazy" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:nt7a3w" />
            <div class="absolute top-4 left-4 bg-primary/90 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest text-white" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5q2">Luxury Pick</div>
            <div class="absolute top-4 right-4" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5q1">
              <WishlistButton 
                client:load 
                venue={{
                  id: "olympic-lagoon-paphos",
                  name: "Five-Star Palace Hotel",
                  location: "Greece",
                  image: "https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?auto=format&w=800&q=80"
                }} 
                iconOnly={true}
              />
            </div>
