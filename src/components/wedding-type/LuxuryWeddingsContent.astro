            <h3 class="text-xl font-bold font-serif text-secondary mb-3" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:399p4p">Five-Star Palace Hotel</h3>
            <p class="text-sm text-muted-foreground mb-4" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:gtbcgk">Step into a world of opulence at this historic palace hotel, featuring grand ballrooms and Michelin-star catering.</p>
            <div class="flex items-baseline gap-2 mb-6" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5py">
              <span class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:5ng2fu">Starting From</span>
              <span class="text-2xl font-bold text-secondary" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:5ng2ft">£12,500</span>
            </div>
            <div class="flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-muted-foreground mb-6" data-ps="src/components/wedding-type/LuxuryWeddingsContent.astro:lay5px">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
