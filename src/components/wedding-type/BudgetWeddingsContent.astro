    <!-- FAQ -->
    <div class="py-12 md:py-24 bg-surface rounded-2xl px-6 md:px-12 mb-10 md:mb-16" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor65">
      <h2 class="text-[36px] font-bold font-serif text-secondary text-center mb-12" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:mi0lip">Frequently Asked Questions</h2>
      <p class="text-muted-foreground text-center mb-10" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:fynl69">Smart ways to plan an affordable destination wedding</p>

      <div class="space-y-4 max-w-3xl mx-auto" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor64">
        <details class="bg-white rounded-xl p-6 group">
          <summary class="flex justify-between items-center cursor-pointer list-none">
            <h3 class="text-[18px] font-bold text-secondary" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:xuoj8p">How can we keep costs down for our destination wedding?</h3>
            <svg class="w-5 h-5 text-primary transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="text-muted-foreground mt-4 leading-relaxed" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:fynl68">Booking out of peak season (May or October), choosing a taverna-style reception, and opting for our essential packages are great ways to have a stunning wedding on a budget.</p>
        </details>

        <details class="bg-white rounded-xl p-6 group">
          <summary class="flex justify-between items-center cursor-pointer list-none">
            <h3 class="text-[18px] font-bold text-secondary" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:xuoj8q">Are low-cost weddings still legally binding?</h3>
            <svg class="w-5 h-5 text-primary transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="text-muted-foreground mt-4 leading-relaxed" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:fynl67">Yes! Regardless of the venue or package price, we ensure all legal requirements are met so your marriage is fully recognised in the UK.</p>
        </details>
      </div>
    </div>

    <!-- Other Wedding Types -->
    <div class="mb-10 md:mb-16" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:xubm50">
      <h2 class="text-[28px] font-bold font-serif text-secondary mb-8 text-center" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:mi0lio">Other Wedding Types</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:xubm51">
        <a href="/wedding-type/luxury-weddings" class="relative rounded-2xl overflow-hidden h-[300px] group no-underline" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:8upoiz">
