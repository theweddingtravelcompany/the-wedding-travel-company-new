        </a>
        <a href="/wedding-type/all-inclusive-weddings" class="relative rounded-2xl overflow-hidden h-[300px] group no-underline" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:8upoiy">
          <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1515934751635-c81c6bc9a2d8?auto=format&w=600&q=80" alt="All Inclusive Weddings" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:iuxvk9" />
