---
// Budget Weddings Content
import { WishlistButton } from '@/components/wishlist/WishlistButton';
---

<section class="py-12 md:py-24 px-4 md:px-6 bg-background" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:kebn0j">
  <div class="max-w-7xl mx-auto" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor8q">
    <!-- Intro -->
    <div class="text-center mb-10 md:mb-16" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor8p">
      <h2 class="text-[42px] font-bold font-serif text-secondary mb-6" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:mi0liq">Beautifully Affordable Budget Weddings</h2>
      <p class="text-muted-foreground text-lg max-w-3xl mx-auto leading-relaxed mb-8" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:fynl72">
        We believe every couple deserves their dream destination wedding, regardless of budget. Our budget-friendly options focus on what matters most—a beautiful location, smooth legal processing, and a celebration shared with those you love.
      </p>
      <p class="text-muted-foreground max-w-3xl mx-auto leading-relaxed mb-8" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:fynl71">
        By choosing from our hand-picked selection of high-value venues and essential packages, you can save thousands while still enjoying a stunning Mediterranean backdrop. Our planners are experts at making every pound go further.
      </p>
      <div class="flex flex-wrap justify-center gap-4 text-[10px] font-bold uppercase tracking-widest" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor83">
        <span class="flex items-center gap-2 text-secondary" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:64z0ku"><svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Essential legal support included</span>
        <span class="flex items-center gap-2 text-secondary" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:64z0kt"><svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Authentic local venue options</span>
        <span class="flex items-center gap-2 text-secondary" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:64z0ks"><svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Transparent, fixed pricing</span>
        <span class="flex items-center gap-2 text-secondary" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:64z0k6"><svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>0% interest monthly payments</span>
      </div>
    </div>

    <!-- Venues Grid -->
    <div class="mb-10 md:mb-16" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor82">
      <div class="flex justify-between items-center mb-8" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor81">
        <h3 class="text-[28px] font-bold font-serif text-secondary" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:xuoj80">Affordable Venues</h3>
        <button class="text-sm text-muted-foreground hover:text-primary transition-colors" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:w07mps">× Close</button>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor80">
        <!-- Venue 1 -->
        <div class="bg-white border border-border rounded-xl overflow-hidden shadow-sm hover-lift" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor7z">
          <div class="relative aspect-video overflow-hidden" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor7y">
            <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1469334031218-e382a71b716b?auto=format&w=800&q=80" alt="Seaside Garden Hotel" class="w-full h-full object-cover" loading="lazy" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:iuxvkd" />
            <div class="absolute top-4 left-4 bg-secondary/90 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest text-white" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor7x">Best Value</div>
            <div class="absolute top-4 right-4" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor7w">
              <WishlistButton 
                client:load 
                venue={{
                  id: "st-raphael-resort",
                  name: "Seaside Garden Hotel",
                  location: "Cyprus",
                  image: "https://images.unsplash.com/photo-1469334031218-e382a71b716b?auto=format&w=800&q=80"
                }} 
                iconOnly={true}
              />
            </div>
          </div>
          <div class="p-6 md:p-8" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor7v">
            <div class="flex items-center gap-2 mb-3" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor7u">
              <div class="bg-white px-2 py-1 rounded-full flex items-center gap-1 shadow-sm border border-border/50" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor72">
                <div class="flex items-center gap-0.5" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor71">
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor70"></div>
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor6z"></div>
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor6d"></div>
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor6c"></div>
                  <div class="relative w-2 h-2 rounded-full bg-[#e0e0e0] overflow-hidden" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor6b">
                    <div class="absolute top-0 left-0 bottom-0 w-1/2 bg-[#00aa6c]" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor6a"></div>
                  </div>
                </div>
                <span class="text-secondary font-bold text-[10px]" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:64z0ex">4.7</span>
              </div>
            </div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground mb-1" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:fynl70">Cyprus • Garden Venue</p>
            <h3 class="text-xl font-bold font-serif text-secondary mb-3" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:xuoj81">Seaside Garden Hotel</h3>
            <p class="text-sm text-muted-foreground mb-4" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:fynl6z">A charming garden venue just steps from the beach, offering affordable wedding packages for intimate groups.</p>
            <div class="flex items-baseline gap-2 mb-6" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor78">
              <span class="text-2xl font-bold text-secondary" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:64z0k3">£1,499</span>
              <span class="text-muted-foreground text-sm" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:64z0k2">Based on 20 guests</span>
            </div>
            <div class="grid grid-cols-2 gap-4" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor77">
              <a href="/venues/st-raphael-resort" class="bg-secondary text-white text-center py-3 rounded-lg text-sm font-bold hover:bg-secondary-hover transition-colors" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:9oc9mh">View Details</a>
              <a href="/enquire2" class="text-primary text-[10px] font-bold uppercase tracking-widest text-center py-3 hover:opacity-80 transition-opacity" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:9oc9mi">Enquire Now</a>
            </div>
          </div>
        </div>

        <!-- Venue 2 -->
        <div class="bg-white border border-border rounded-xl overflow-hidden shadow-sm hover-lift" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor76">
          <div class="relative aspect-video overflow-hidden" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor75">
            <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1679193559799-4bdc724dfc45?auto=format&w=800&q=80" alt="Traditional Greek Taverna" class="w-full h-full object-cover" loading="lazy" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:iuxvkc" />
            <div class="absolute top-4 left-4 bg-secondary/90 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest text-white" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor74">Best Value</div>
            <div class="absolute top-4 right-4" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor73">
              <WishlistButton 
                client:load 
                venue={{
                  id: "olympic-lagoon-paphos",
                  name: "Traditional Greek Taverna",
                  location: "Rhodes",
                  image: "https://images.unsplash.com/photo-1679193559799-4bdc724dfc45?auto=format&w=800&q=80"
                }} 
                iconOnly={true}
              />
            </div>
          </div>
          <div class="p-6 md:p-8" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor72">
            <div class="flex items-center gap-2 mb-3" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor71">
              <div class="bg-white px-2 py-1 rounded-full flex items-center gap-1 shadow-sm border border-border/50" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor69">
                <div class="flex items-center gap-0.5" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor68">
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor67"></div>
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor66"></div>
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor65"></div>
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor64"></div>
                  <div class="relative w-2 h-2 rounded-full bg-[#e0e0e0] overflow-hidden" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:xubm50">
                    <div class="absolute top-0 left-0 bottom-0 w-1/2 bg-[#00aa6c]" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:xubm51"></div>
                  </div>
                </div>
                <span class="text-secondary font-bold text-[10px]" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:64z0ew">4.8</span>
              </div>
            </div>
