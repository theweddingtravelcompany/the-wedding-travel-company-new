            <h3 class="text-xl font-bold font-serif text-secondary mb-3" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:xuoj8n">Traditional Greek Taverna</h3>
            <p class="text-sm text-muted-foreground mb-4" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:fynl6x">Celebrate your love with authentic Greek hospitality, stunning sunset views, and incredible value for money.</p>
            <div class="flex items-baseline gap-2 mb-6" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor70">
              <span class="text-2xl font-bold text-secondary" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:64z0jz">£1,200</span>
              <span class="text-muted-foreground text-sm" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:64z0jy">Based on 30 guests</span>
            </div>
            <div class="grid grid-cols-2 gap-4" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor6z">
              <a href="/venues/st-raphael-resort/" class="bg-secondary text-white text-center py-3 rounded-lg text-sm font-bold hover:bg-secondary-hover transition-colors" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:9oc9mj">View Details</a>
              <a href="/enquire2" class="text-primary text-[10px] font-bold uppercase tracking-widest text-center py-3 hover:opacity-80 transition-opacity" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:9oc9mk">Enquire Now</a>
            </div>
          </div>
        </div>

        <!-- Venue 3 -->
        <div class="bg-white border border-border rounded-xl overflow-hidden shadow-sm hover-lift" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor6d">
          <div class="relative aspect-video overflow-hidden" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor6c">
            <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1522441815192-d9f04eb0615c?auto=format&w=800&q=80" alt="Hilltop Chapel" class="w-full h-full object-cover" loading="lazy" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:iuxvkb" />
            <div class="absolute top-4 left-4 bg-secondary/90 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest text-white" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor6b">Best Value</div>
            <div class="absolute top-4 right-4" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor6a">
              <WishlistButton 
                client:load 
                venue={{
                  id: "vasilias-nikoklis-inn",
                  name: "Hilltop Chapel",
                  location: "Crete",
                  image: "https://images.unsplash.com/photo-1522441815192-d9f04eb0615c?auto=format&w=800&q=80"
                }} 
                iconOnly={true}
              />
            </div>
          </div>
          <div class="p-6 md:p-8" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor69">
            <div class="flex items-center gap-2 mb-3" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor68">
              <div class="bg-white px-2 py-1 rounded-full flex items-center gap-1 shadow-sm border border-border/50" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:xubm52">
                <div class="flex items-center gap-0.5" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:xubm53">
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:xubm54"></div>
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:xubm55"></div>
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:xubm56"></div>
                  <div class="w-2 h-2 rounded-full bg-[#00aa6c]" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:xubm57"></div>
                  <div class="relative w-2 h-2 rounded-full bg-[#e0e0e0] overflow-hidden" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:xubm58">
                    <div class="absolute top-0 left-0 bottom-0 w-1/2 bg-[#00aa6c]" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:xubm59"></div>
                  </div>
                </div>
                <span class="text-secondary font-bold text-[10px]" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:64z0ev">4.9</span>
              </div>
            </div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground mb-1" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:fynl6w">Crete • Chapel</p>
            <h3 class="text-xl font-bold font-serif text-secondary mb-3" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:xuoj8o">Hilltop Chapel</h3>
            <p class="text-sm text-muted-foreground mb-4" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:fynl6a">A simple yet beautiful hilltop ceremony location that lets the natural Mediterranean landscape be your decor.</p>
            <div class="flex items-baseline gap-2 mb-6" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor67">
              <span class="text-2xl font-bold text-secondary" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:64z0ja">£999</span>
              <span class="text-muted-foreground text-sm" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:64z0j9">Based on 15 guests</span>
            </div>
            <div class="grid grid-cols-2 gap-4" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:gcor66">
              <a href="/venues/st-raphael-resort/" class="bg-secondary text-white text-center py-3 rounded-lg text-sm font-bold hover:bg-secondary-hover transition-colors" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:8upoj1">View Details</a>
              <a href="/enquire2" class="text-primary text-[10px] font-bold uppercase tracking-widest text-center py-3 hover:opacity-80 transition-opacity" data-ps="src/components/wedding-type/BudgetWeddingsContent.astro:8upoj0">Enquire Now</a>
            </div>
          </div>
        </div>
      </div>
