          <li data-ps="src/components/Footer.astro:wyji37"><a href="/destinations/corfu" class="text-xs hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqbzj">Corfu</a></li>
          <li data-ps="src/components/Footer.astro:wyji3t"><a href="/destinations/kos" class="text-xs hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqbzk">Kos</a></li>
          <li data-ps="src/components/Footer.astro:wyji3u"><a href="/destinations/halkidiki" class="text-xs hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqbzl">Halkidiki</a></li>
          <li data-ps="src/components/Footer.astro:wyji3v"><a href="/destinations/athens" class="text-xs hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqbzm">Athens</a></li>
        </ul>
