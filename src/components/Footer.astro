          <li data-ps="src/components/Footer.astro:wyji26"><a href="/cookies" class="text-xs no-underline hover:text-white transition-colors text-secondary-foreground" data-ps="src/components/Footer.astro:8o2pf">Cookie Policy</a></li>
        </ul>
        <h3 class="text-white text-[10px] font-bold uppercase tracking-widest mb-6" data-ps="src/components/Footer.astro:fh1w68">EXPLORE</h3>
        <ul class="flex flex-col gap-3 list-none p-0">
          <li data-ps="src/components/Footer.astro:wyji27"><a href="/destinations/all-destinations" class="text-xs no-underline hover:text-white transition-colors text-secondary-foreground" data-ps="src/components/Footer.astro:7gqc0h">Browse Venues</a></li>
          <li data-ps="src/components/Footer.astro:wyji28"><a href="/#three-steps" class="text-xs no-underline hover:text-white transition-colors text-secondary-foreground" data-ps="src/components/Footer.astro:7gqc0i">How it Works</a></li>
          <li data-ps="src/components/Footer.astro:wyji29"><a href="/design-your-dream-wedding" class="text-xs no-underline hover:text-white transition-colors text-secondary-foreground" data-ps="src/components/Footer.astro:7gqc0j">Wedding Planner</a></li>
          <li data-ps="src/components/Footer.astro:wyji2a"><a href="/enquire2" class="text-xs no-underline hover:text-white transition-colors text-secondary-foreground" data-ps="src/components/Footer.astro:7gqc0k">Enquire Now</a></li>
          <li data-ps="src/components/Footer.astro:wyji2b"><a href="/careers" class="text-xs no-underline hover:text-white transition-colors text-secondary-foreground" data-ps="src/components/Footer.astro:7gqc0l">Careers</a></li>
        </ul>
      </div>

