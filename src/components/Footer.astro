          <li data-ps="src/components/Footer.astro:wyji34"><a href="/destinations/crete" class="text-xs hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqbyv">Crete</a></li>
          <li data-ps="src/components/Footer.astro:wyji35"><a href="/destinations/skiathos" class="text-xs hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqbyw">Skiathos</a></li>
