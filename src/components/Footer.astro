        </ul>
      </div>

      <div data-ps="src/components/Footer.astro:dest-3">
        <h3 class="text-white text-[10px] font-bold uppercase tracking-widest mb-6" data-ps="src/components/Footer.astro:fh1w67">SPAIN</h3>
        <ul class="flex flex-col gap-3 list-none p-0">
          <li data-ps="src/components/Footer.astro:wyji4r"><a href="/destinations/ibiza" class="text-xs hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqc0i">Ibiza</a></li>
