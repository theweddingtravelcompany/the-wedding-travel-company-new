---
import { SITE } from '@/config/site';
---

<footer class="bg-secondary text-secondary-foreground py-24 px-6" data-ps="src/components/Footer.astro:ikmf32">
  <div class="max-w-7xl mx-auto" data-ps="src/components/Footer.astro:p4vf87">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12 mb-16" data-ps="src/components/Footer.astro:p4vf88">
      <!-- Brand -->
      <div class="lg:col-span-1" data-ps="src/components/Footer.astro:brand">
        <h2 class="text-xl font-bold text-white mb-6 uppercase tracking-widest" data-ps="src/components/Footer.astro:f0091a">
          THE WEDDING <span class="text-secondary-foreground italic font-serif lowercase" data-ps="src/components/Footer.astro:hzwfpg">travel</span> CO.
        </h2>
        <p class="text-sm leading-relaxed mb-8" data-ps="src/components/Footer.astro:euon">
          Curated weddings in paradise. Tell us the vibe you want — we'll match you with beautiful wedding venues across our destinations.
        </p>
        <div class="flex gap-4 mb-8" data-ps="src/components/Footer.astro:p4vf8b">
          <a href="/#" class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center text-white hover:text-primary hover:border-primary transition-colors" aria-label="Instagram" data-ps="src/components/Footer.astro:7gqc0f">
