    <!-- Bottom Bar -->
    <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center text-[10px] font-semibold uppercase tracking-widest gap-4" data-ps="src/components/Footer.astro:p4vf8b">
