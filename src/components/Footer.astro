      <div data-ps="src/components/Footer.astro:dest-2">
        <h3 class="text-white text-[10px] font-bold uppercase tracking-widest mb-6" data-ps="src/components/Footer.astro:fh1w69">ITALY WEDDINGS</h3>
        <ul class="flex flex-col gap-3 list-none p-0">
