---
// Rhodes Venues Section
import { WishlistButton } from '@/components/wishlist/WishlistButton';
import { VenueImageSlider } from '@/components/destinations/VenueImageSlider';
---

<section class="py-24 px-6 bg-background" data-ps="src/components/destinations/rhodes/RhodesVenues.astro:7n8m11">
  <div class="max-w-7xl mx-auto" data-ps="src/components/destinations/rhodes/RhodesVenues.astro:f5o1sy">
    <div class="text-center mb-16" data-ps="src/components/destinations/rhodes/RhodesVenues.astro:f5o1sx">
      <h2 class="text-[42px] font-bold font-serif text-secondary mb-4" data-ps="src/components/destinations/rhodes/RhodesVenues.astro:68krab">Your Dream Rhodes Wedding</h2>
      <p class="text-muted-foreground max-w-3xl mx-auto leading-relaxed" data-ps="src/components/destinations/rhodes/RhodesVenues.astro:2n33tn">
        Rhodes, the island of knights, is one of the most popular wedding destinations in Greece. With over 300 days of sunshine a year, it offers the perfect blend of Mediterranean charm, ancient history, and reliable weather.
      </p>
    </div>

    <div class="bg-surface rounded-2xl p-8 mb-12" data-ps="src/components/destinations/rhodes/RhodesVenues.astro:f5o1sw">
      <div class="flex flex-wrap gap-6 justify-center text-[10px] font-bold uppercase tracking-widest" data-ps="src/components/destinations/rhodes/RhodesVenues.astro:f5o1sv">
        <span class="flex items-center gap-2 text-secondary" data-ps="src/components/destinations/rhodes/RhodesVenues.astro:5r20kd"><svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>English-speaking wedding specialists</span>
        <span class="flex items-center gap-2 text-secondary" data-ps="src/components/destinations/rhodes/RhodesVenues.astro:5r20ke"><svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Legally recognised ceremonies</span>
        <span class="flex items-center gap-2 text-secondary" data-ps="src/components/destinations/rhodes/RhodesVenues.astro:5r20kf"><svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Stunning sunset backdrops</span>
        <span class="flex items-center gap-2 text-secondary" data-ps="src/components/destinations/rhodes/RhodesVenues.astro:5r20kg"><svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Exceptional hospitality & food</span>
      </div>
    </div>

    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 gap-4" data-ps="src/components/destinations/rhodes/RhodesVenues.astro:f5o1su">
      <div data-ps="src/components/destinations/rhodes/RhodesVenues.astro:f5o1st">
        <h3 class="text-[28px] font-bold font-serif text-secondary" data-ps="src/components/destinations/rhodes/RhodesVenues.astro:kwzohy">Selected Venues</h3>
        <p class="text-muted-foreground" data-ps="src/components/destinations/rhodes/RhodesVenues.astro:2n33t1">Whether you envision a barefoot ceremony on the golden sands, a romantic sunset wedding overlooking the Acropolis of Lindos, or a rustic celebration in a traditional village, Rhodes has a venue to match every vision.</p>
      </div>
      <div class="flex items-center gap-2" data-ps="src/components/destinations/rhodes/RhodesVenues.astro:f5o1ss">
        <span class="text-sm text-muted-foreground" data-ps="src/components/destinations/rhodes/RhodesVenues.astro:5r20l2">Venue Type</span>
        <select class="border border-border rounded-lg px-4 py-2 text-sm bg-white">
          <option>All Venues</option>
        </select>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8" data-ps="src/components/destinations/rhodes/RhodesVenues.astro:f5o1y1">
