          </div>
          <div class="absolute top-4 right-4 z-10" data-ps="src/components/destinations/rhodes/RhodesVenues.astro:f5o1xx">
          <WishlistButton 
          client:load
          venue={{
          id: "kalithea-springs",
          name: "Kalithea Springs",
          location: "Rhodes, Greece",
          image: "https://images.pexels.com/photos/13538484/pexels-photo-13538484.jpeg?auto=compress&cs=tinysrgb&w=800",
          priceFrom: "£2,999",
          url: "/venues/kalithea-springs"
          }} 
          iconOnly={true} 
          />
          </div>
        </div>
        <div class="p-8 flex flex-col flex-grow" data-ps="src/components/destinations/rhodes/RhodesVenues.astro:f5o1xb">
