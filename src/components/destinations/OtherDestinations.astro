---
// Other Wedding Destinations Carousel Component
---

<section id="other-destinations" class="pt-8 pb-24 px-6 bg-surface" data-ps="src/components/destinations/OtherDestinations.astro:other">
  <div class="max-w-7xl mx-auto" data-ps="src/components/destinations/OtherDestinations.astro:container">
    <div class="text-center mb-16" data-ps="src/components/destinations/OtherDestinations.astro:header">
      <h2 class="text-[42px] font-bold font-serif text-secondary mb-4" data-ps="src/components/destinations/OtherDestinations.astro:title">
        Other Wedding <span class="text-primary italic font-normal" data-ps="src/components/destinations/OtherDestinations.astro:ital">Destinations</span>
      </h2>
      <p class="text-muted-foreground max-w-2xl mx-auto" data-ps="src/components/destinations/OtherDestinations.astro:desc">Explore more breathtaking locations for your dream day.</p>
    </div>

    <div class="relative group" data-ps="src/components/destinations/OtherDestinations.astro:slider-wrapper">
      <!-- Left Arrow -->
      <button id="other-dest-left" class="absolute left-2 md:-left-6 top-1/2 -translate-y-1/2 z-10 bg-white hover:bg-surface text-secondary w-10 h-10 md:w-14 md:h-14 rounded-full shadow-[0_8px_30px_rgb(0,0,0,0.12)] flex items-center justify-center opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-all duration-300 hover:scale-105" aria-label="Previous destination" data-ps="src/components/destinations/OtherDestinations.astro:left-btn">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 md:w-6 md:h-6"><path d="m15 18-6-6 6-6"/></svg>
      </button>

      <div id="other-dest-slider" class="flex overflow-x-auto snap-x snap-mandatory gap-4 md:gap-8 pb-8 -mx-6 px-6 md:mx-0 md:px-0 [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]" data-ps="src/components/destinations/OtherDestinations.astro:slider">
        <!-- Greece -->
        <a href="/destinations/greece" class="w-[85vw] md:w-[calc(50%-16px)] lg:w-[calc(25%-24px)] shrink-0 snap-start relative rounded-2xl overflow-hidden h-[400px] md:h-[450px] group/card no-underline" data-ps="src/components/destinations/OtherDestinations.astro:dest-greece">
          <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1761047726499-f5a50b9fe003?auto=format&w=800&q=80" alt="Greece" class="w-full h-full object-cover transition-transform duration-500 group-hover/card:scale-110" loading="lazy" data-ps="src/components/destinations/OtherDestinations.astro:img-greece" />
          <div class="absolute inset-0 bg-gradient-to-t from-secondary/80 to-transparent" data-ps="src/components/destinations/OtherDestinations.astro:8a21fi"></div>
          <div class="absolute bottom-0 left-0 p-8 w-full transition-transform duration-300 transform group-hover/card:-translate-y-4" data-ps="src/components/destinations/OtherDestinations.astro:8a21fh">
            <h3 class="text-2xl font-bold font-serif text-white mb-2" data-ps="src/components/destinations/OtherDestinations.astro:f7uf9n">Greece</h3>
            <p class="text-white/80 text-[10px] font-bold uppercase tracking-widest" data-ps="src/components/destinations/OtherDestinations.astro:5nyw0v">From £3,499</p>
            <div class="opacity-100 md:opacity-0 md:group-hover/card:opacity-100 transition-opacity duration-300 mt-6" data-ps="src/components/destinations/OtherDestinations.astro:8a21fg">
              <span class="inline-block bg-primary text-white text-[10px] font-bold uppercase tracking-widest px-6 py-3 rounded-lg w-full text-center" data-ps="src/components/destinations/OtherDestinations.astro:9q46ly">View Venues</span>
            </div>
          </div>
        </a>

        <!-- Italy -->
        <a href="/destinations/italy" class="w-[85vw] md:w-[calc(50%-16px)] lg:w-[calc(25%-24px)] shrink-0 snap-start relative rounded-2xl overflow-hidden h-[400px] md:h-[450px] group/card no-underline" data-ps="src/components/destinations/OtherDestinations.astro:dest-italy">
          <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1612885488634-0a698136fed9?auto=format&w=800&q=80" alt="Italy" class="w-full h-full object-cover transition-transform duration-500 group-hover/card:scale-110" loading="lazy" data-ps="src/components/destinations/OtherDestinations.astro:img-italy" />
          <div class="absolute inset-0 bg-gradient-to-t from-secondary/80 to-transparent" data-ps="src/components/destinations/OtherDestinations.astro:8a21ff"></div>
          <div class="absolute bottom-0 left-0 p-8 w-full transition-transform duration-300 transform group-hover/card:-translate-y-4" data-ps="src/components/destinations/OtherDestinations.astro:8a21fe">
            <h3 class="text-2xl font-bold font-serif text-white mb-2" data-ps="src/components/destinations/OtherDestinations.astro:f7uf9m">Italy</h3>
            <p class="text-white/80 text-[10px] font-bold uppercase tracking-widest" data-ps="src/components/destinations/OtherDestinations.astro:5nyw0u">From £4,200</p>
            <div class="opacity-100 md:opacity-0 md:group-hover/card:opacity-100 transition-opacity duration-300 mt-6" data-ps="src/components/destinations/OtherDestinations.astro:4bcywy">
              <span class="inline-block bg-primary text-white text-[10px] font-bold uppercase tracking-widest px-6 py-3 rounded-lg w-full text-center" data-ps="src/components/destinations/OtherDestinations.astro:9q46lz">View Venues</span>
            </div>
          </div>
        </a>

        <!-- Spain -->
        <a href="/destinations/spain" class="w-[85vw] md:w-[calc(50%-16px)] lg:w-[calc(25%-24px)] shrink-0 snap-start relative rounded-2xl overflow-hidden h-[400px] md:h-[450px] group/card no-underline" data-ps="src/components/destinations/OtherDestinations.astro:dest-spain">
          <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1762872502140-0026fe0c8f33?auto=format&w=800&q=80" alt="Spain" class="w-full h-full object-cover transition-transform duration-500 group-hover/card:scale-110" loading="lazy" data-ps="src/components/destinations/OtherDestinations.astro:img-spain" />
          <div class="absolute inset-0 bg-gradient-to-t from-secondary/80 to-transparent" data-ps="src/components/destinations/OtherDestinations.astro:4bcywz"></div>
          <div class="absolute bottom-0 left-0 p-8 w-full transition-transform duration-300 transform group-hover/card:-translate-y-4" data-ps="src/components/destinations/OtherDestinations.astro:4bcyx0">
            <h3 class="text-2xl font-bold font-serif text-white mb-2" data-ps="src/components/destinations/OtherDestinations.astro:f7uf9l">Spain</h3>
            <p class="text-white/80 text-[10px] font-bold uppercase tracking-widest" data-ps="src/components/destinations/OtherDestinations.astro:5nyw0t">From £2,950</p>
            <div class="opacity-100 md:opacity-0 md:group-hover/card:opacity-100 transition-opacity duration-300 mt-6" data-ps="src/components/destinations/OtherDestinations.astro:4bcyx1">
              <span class="inline-block bg-primary text-white text-[10px] font-bold uppercase tracking-widest px-6 py-3 rounded-lg w-full text-center" data-ps="src/components/destinations/OtherDestinations.astro:9q46m0">View Venues</span>
            </div>
          </div>
        </a>

        <!-- Malta -->
        <a href="/destinations/malta" class="w-[85vw] md:w-[calc(50%-16px)] lg:w-[calc(25%-24px)] shrink-0 snap-start relative rounded-2xl overflow-hidden h-[400px] md:h-[450px] group/card no-underline" data-ps="src/components/destinations/OtherDestinations.astro:dest-malta">
          <img src="https://images.pexels.com/photos/33345640/pexels-photo-33345640.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Malta" class="w-full h-full object-cover transition-transform duration-500 group-hover/card:scale-110" loading="lazy" data-ps="src/components/destinations/OtherDestinations.astro:img-malta" />
          <div class="absolute inset-0 bg-gradient-to-t from-secondary/80 to-transparent" data-ps="src/components/destinations/OtherDestinations.astro:4bcyx2"></div>
          <div class="absolute bottom-0 left-0 p-8 w-full transition-transform duration-300 transform group-hover/card:-translate-y-4" data-ps="src/components/destinations/OtherDestinations.astro:4bcyx3">
            <h3 class="text-2xl font-bold font-serif text-white mb-2" data-ps="src/components/destinations/OtherDestinations.astro:f7uf9k">Malta</h3>
            <p class="text-white/80 text-[10px] font-bold uppercase tracking-widest" data-ps="src/components/destinations/OtherDestinations.astro:5nyw0s">From £2,999</p>
            <div class="opacity-100 md:opacity-0 md:group-hover/card:opacity-100 transition-opacity duration-300 mt-6" data-ps="src/components/destinations/OtherDestinations.astro:4bcyx4">
              <span class="inline-block bg-primary text-white text-[10px] font-bold uppercase tracking-widest px-6 py-3 rounded-lg w-full text-center" data-ps="src/components/destinations/OtherDestinations.astro:9q46m1">View Venues</span>
            </div>
          </div>
        </a>

        <!-- Turkey -->
        <a href="/destinations/turkey" class="w-[85vw] md:w-[calc(50%-16px)] lg:w-[calc(25%-24px)] shrink-0 snap-start relative rounded-2xl overflow-hidden h-[400px] md:h-[450px] group/card no-underline" data-ps="src/components/destinations/OtherDestinations.astro:dest-turkey">
          <img src="https://images.pexels.com/photos/29205400/pexels-photo-29205400.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Turkey" class="w-full h-full object-cover transition-transform duration-500 group-hover/card:scale-110" loading="lazy" data-ps="src/components/destinations/OtherDestinations.astro:img-turkey" />
          <div class="absolute inset-0 bg-gradient-to-t from-secondary/80 to-transparent" data-ps="src/components/destinations/OtherDestinations.astro:4bcyx5"></div>
          <div class="absolute bottom-0 left-0 p-8 w-full transition-transform duration-300 transform group-hover/card:-translate-y-4" data-ps="src/components/destinations/OtherDestinations.astro:4bcyx6">
            <h3 class="text-2xl font-bold font-serif text-white mb-2" data-ps="src/components/destinations/OtherDestinations.astro:f7uf9j">Turkey</h3>
            <p class="text-white/80 text-[10px] font-bold uppercase tracking-widest" data-ps="src/components/destinations/OtherDestinations.astro:5nyw0r">From £3,100</p>
            <div class="opacity-100 md:opacity-0 md:group-hover/card:opacity-100 transition-opacity duration-300 mt-6" data-ps="src/components/destinations/OtherDestinations.astro:4bcyx7">
              <span class="inline-block bg-primary text-white text-[10px] font-bold uppercase tracking-widest px-6 py-3 rounded-lg w-full text-center" data-ps="src/components/destinations/OtherDestinations.astro:9q46m2">View Venues</span>
            </div>
          </div>
        </a>
      </div>

      <!-- Right Arrow -->
      <button id="other-dest-right" class="absolute right-2 md:-right-6 top-1/2 -translate-y-1/2 z-10 bg-white hover:bg-surface text-secondary w-10 h-10 md:w-14 md:h-14 rounded-full shadow-[0_8px_30px_rgb(0,0,0,0.12)] flex items-center justify-center opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-all duration-300 hover:scale-105" aria-label="Next destination" data-ps="src/components/destinations/OtherDestinations.astro:right-btn">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 md:w-6 md:h-6"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>

    <script>
      const slider = document.getElementById('other-dest-slider');
      const leftBtn = document.getElementById('other-dest-left');
      const rightBtn = document.getElementById('other-dest-right');

      if (slider && leftBtn && rightBtn) {
        leftBtn.addEventListener('click', () => {
          const scrollAmount = window.innerWidth < 768 ? window.innerWidth * 0.85 : slider.offsetWidth / 2;
          slider.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
        });
        
        rightBtn.addEventListener('click', () => {
          const scrollAmount = window.innerWidth < 768 ? window.innerWidth * 0.85 : slider.offsetWidth / 2;
          slider.scrollBy({ left: scrollAmount, behavior: 'smooth' });
        });
      }
    </script>
  </div>
</section>