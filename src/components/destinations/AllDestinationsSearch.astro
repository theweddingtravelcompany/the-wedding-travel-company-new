---
// Quick Search Section
---

<section class="py-16 px-6 bg-surface" data-ps="src/components/destinations/AllDestinationsSearch.astro:aflbr7">
  <div class="max-w-5xl mx-auto" data-ps="src/components/destinations/AllDestinationsSearch.astro:tvuzxo">
    <div class="bg-white rounded-2xl p-8 shadow-sm" data-ps="src/components/destinations/AllDestinationsSearch.astro:tvuzxp">
      <h2 class="text-[28px] font-bold font-serif text-secondary mb-8 text-center" data-ps="src/components/destinations/AllDestinationsSearch.astro:rs5uni">Quick Search</h2>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6" data-ps="src/components/destinations/AllDestinationsSearch.astro:tvuzxq">
        <div data-ps="src/components/destinations/AllDestinationsSearch.astro:tvuzxr">
          <label class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground block mb-2" data-ps="src/components/destinations/AllDestinationsSearch.astro:lodtc3">Destination</label>
          <select class="w-full border border-border rounded-lg px-4 py-3 text-sm appearance-none bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20fill%3D%22none%22%20viewBox%3D%220%200%2024%2024%22%20stroke%3D%22%23737373%22%3E%3Cpath%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%20stroke-width%3D%222%22%20d%3D%22M19%209l-7%207-7-7%22%2F%3E%3C%2Fsvg%3E')] bg-[length:1.25em_1.25em] bg-[right_1rem_center] bg-no-repeat focus:outline-none focus:ring-1 focus:ring-primary">
            <option>All Destinations</option>
            <option>Cyprus</option>
            <option>Greece</option>
            <option>Italy</option>
          </select>
        </div>
        <div data-ps="src/components/destinations/AllDestinationsSearch.astro:tvuzxs">
          <label class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground block mb-2" data-ps="src/components/destinations/AllDestinationsSearch.astro:lodtc4">Budget</label>
          <select class="w-full border border-border rounded-lg px-4 py-3 text-sm appearance-none bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20fill%3D%22none%22%20viewBox%3D%220%200%2024%2024%22%20stroke%3D%22%23737373%22%3E%3Cpath%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%20stroke-width%3D%222%22%20d%3D%22M19%209l-7%207-7-7%22%2F%3E%3C%2Fsvg%3E')] bg-[length:1.25em_1.25em] bg-[right_1rem_center] bg-no-repeat focus:outline-none focus:ring-1 focus:ring-primary">
            <option>Any Budget</option>
            <option>Up to £5,000</option>
            <option>Up to £10,000</option>
          </select>
        </div>
        <div data-ps="src/components/destinations/AllDestinationsSearch.astro:tvuzxt">
          <label class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground block mb-2" data-ps="src/components/destinations/AllDestinationsSearch.astro:lodtc5">Guests</label>
          <select class="w-full border border-border rounded-lg px-4 py-3 text-sm appearance-none bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20fill%3D%22none%22%20viewBox%3D%220%200%2024%2024%22%20stroke%3D%22%23737373%22%3E%3Cpath%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%20stroke-width%3D%222%22%20d%3D%22M19%209l-7%207-7-7%22%2F%3E%3C%2Fsvg%3E')] bg-[length:1.25em_1.25em] bg-[right_1rem_center] bg-no-repeat focus:outline-none focus:ring-1 focus:ring-primary">
            <option>Any Size</option>
            <option>Up to 50</option>
            <option>50 - 100</option>
          </select>
        </div>
        <div class="flex items-end" data-ps="src/components/destinations/AllDestinationsSearch.astro:tvuzxu">
          <a href="/wedding-search/" class="w-full text-center bg-primary text-white py-3 rounded-lg font-bold uppercase tracking-widest text-[12px] hover:bg-primary-hover transition-colors inline-block no-underline" data-ps="src/components/destinations/AllDestinationsSearch.astro:vxannb">
            Search
          </a>
        </div>
      </div>
    </div>
  </div>
</section>