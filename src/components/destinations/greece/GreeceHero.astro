---
// Greece Destination Hero
---
<section class="relative bg-secondary min-h-[600px] flex items-center py-20 px-6 overflow-hidden" data-ps="src/components/destinations/greece/GreeceHero.astro:d0u1th">
  <div class="absolute inset-0 z-0" data-ps="src/components/destinations/greece/GreeceHero.astro:kxdmoc">
    <img src="https://images.pexels.com/photos/18774893/pexels-photo-18774893.jpeg?auto=compress&cs=tinysrgb&w=1920"
      srcset="https://images.pexels.com/photos/18774893/pexels-photo-18774893.jpeg?auto=compress&cs=tinysrgb&w=320 320w, https://images.pexels.com/photos/18774893/pexels-photo-18774893.jpeg?auto=compress&cs=tinysrgb&w=768 768w, https://images.pexels.com/photos/18774893/pexels-photo-18774893.jpeg?auto=compress&cs=tinysrgb&w=1920 1920w"
      sizes="100vw"
      alt="Wedding in Greece"
      class="w-full h-full object-cover"
      loading="eager" data-ps="src/components/destinations/greece/GreeceHero.astro:k8hgni" />
    <div class="absolute inset-0 bg-secondary/50" data-ps="src/components/destinations/greece/GreeceHero.astro:kxdmob"></div>
  </div>

  <div class="max-w-7xl mx-auto w-full relative z-10 text-white" data-ps="src/components/destinations/greece/GreeceHero.astro:kxdmoa">
    <h1 class="text-[48px] md:text-[72px] font-bold font-serif leading-tight mb-6" data-ps="src/components/destinations/greece/GreeceHero.astro:htrknb">
      Weddings in Greece
    </h1>
    <p class="text-[24px] text-white/80 max-w-2xl mb-8" data-ps="src/components/destinations/greece/GreeceHero.astro:qm7i0h">
      Award-winning destination wedding specialists trusted by 1,000+ couples each year.
    </p>
    <div class="flex flex-wrap gap-4 text-[10px] font-bold uppercase tracking-widest mb-8" data-ps="src/components/destinations/greece/GreeceHero.astro:kxdmo9">
      <span data-ps="src/components/destinations/greece/GreeceHero.astro:79g2cv">ABTA BONDED</span>
      <span data-ps="src/components/destinations/greece/GreeceHero.astro:79g2cw">|</span>
      <span data-ps="src/components/destinations/greece/GreeceHero.astro:79g2cx">0% INTEREST PAYMENT PLANS</span>
      <span data-ps="src/components/destinations/greece/GreeceHero.astro:79g2cy">|</span>
      <span data-ps="src/components/destinations/greece/GreeceHero.astro:vue356">IN-HOUSE LEGAL TEAM</span>
    </div>
    <p class="text-white/60 text-sm" data-ps="src/components/destinations/greece/GreeceHero.astro:qm7i0i">Book up to 3 years ahead • Low deposits • Interest free monthly instalments</p>
    <a href="/enquire2" class="inline-block mt-8 bg-primary text-white px-8 py-4 rounded-xl font-bold uppercase tracking-widest text-[12px] hover:bg-primary-hover transition-colors" data-ps="src/components/destinations/greece/GreeceHero.astro:k4y8ga">
      Get My Personalised Quote
    </a>
  </div>
</section>