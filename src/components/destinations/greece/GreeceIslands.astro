---
// Greece Islands Grid
---
<section class="py-24 px-6 bg-surface" data-ps="src/components/destinations/greece/GreeceIslands.astro:9sv5kr">
  <div class="max-w-7xl mx-auto" data-ps="src/components/destinations/greece/GreeceIslands.astro:hhsxg4">
    <div class="text-center mb-16" data-ps="src/components/destinations/greece/GreeceIslands.astro:hhsxg5">
      <h2 class="text-[42px] font-bold font-serif text-secondary mb-4" data-ps="src/components/destinations/greece/GreeceIslands.astro:b5ydt3">Choose Your Greek Island</h2>
      <p class="text-muted-foreground max-w-3xl mx-auto leading-relaxed" data-ps="src/components/destinations/greece/GreeceIslands.astro:88ntlb">
        From the stunning sunsets of Santorini to the ancient charm of Rhodes, explore our stunning locations across the Greek islands.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" data-ps="src/components/destinations/greece/GreeceIslands.astro:hhsxg6">
      <!-- Rhodes -->
      <a href="/destinations/greece/rhodes" class="group block relative rounded-2xl overflow-hidden aspect-[4/5] shadow-sm" data-ps="src/components/destinations/greece/GreeceIslands.astro:14pwvk">
        <div class="absolute inset-0 bg-secondary/20 group-hover:bg-transparent transition-colors duration-500 z-10" data-ps="src/components/destinations/greece/GreeceIslands.astro:hhsxg7"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-secondary/90 via-secondary/40 to-transparent z-10" data-ps="src/components/destinations/greece/GreeceIslands.astro:hhsxg8"></div>
        <img src="https://images.pexels.com/photos/33151489/pexels-photo-33151489.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Rhodes" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" data-ps="src/components/destinations/greece/GreeceIslands.astro:ezjt4k" />
        <div class="absolute bottom-0 left-0 right-0 p-8 z-20" data-ps="src/components/destinations/greece/GreeceIslands.astro:c0r4vk">
          <h3 class="text-3xl font-serif font-bold text-white mb-2" data-ps="src/components/destinations/greece/GreeceIslands.astro:3igjf5">Rhodes</h3>
          <p class="text-white/80 text-sm" data-ps="src/components/destinations/greece/GreeceIslands.astro:88ntla">Stunning beaches & ancient history</p>
          <div class="mt-4 flex items-center text-white text-[10px] font-bold uppercase tracking-widest gap-2" data-ps="src/components/destinations/greece/GreeceIslands.astro:c0r4vl">
            Explore <svg class="w-4 h-4 group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </div>
        </div>
      </a>
      
      <!-- Santorini -->
      <a href="/enquire2" class="group block relative rounded-2xl overflow-hidden aspect-[4/5] shadow-sm" data-ps="src/components/destinations/greece/GreeceIslands.astro:14pwvj">
        <div class="absolute inset-0 bg-secondary/20 group-hover:bg-transparent transition-colors duration-500 z-10" data-ps="src/components/destinations/greece/GreeceIslands.astro:c0r4vm"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-secondary/90 via-secondary/40 to-transparent z-10" data-ps="src/components/destinations/greece/GreeceIslands.astro:c0r4vn"></div>
        <img src="https://images.pexels.com/photos/18774893/pexels-photo-18774893.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Santorini" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" data-ps="src/components/destinations/greece/GreeceIslands.astro:ezjt4l" />
        <div class="absolute bottom-0 left-0 right-0 p-8 z-20" data-ps="src/components/destinations/greece/GreeceIslands.astro:c0r4vo">
          <h3 class="text-3xl font-serif font-bold text-white mb-2" data-ps="src/components/destinations/greece/GreeceIslands.astro:3igjf4">Santorini</h3>
          <p class="text-white/80 text-sm" data-ps="src/components/destinations/greece/GreeceIslands.astro:88ntl9">Iconic sunsets & whitewashed churches</p>
          <div class="mt-4 flex items-center text-white text-[10px] font-bold uppercase tracking-widest gap-2" data-ps="src/components/destinations/greece/GreeceIslands.astro:c0r4vp">
            Explore <svg class="w-4 h-4 group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </div>
        </div>
      </a>
      
      <!-- Zante -->
      <a href="/enquire2" class="group block relative rounded-2xl overflow-hidden aspect-[4/5] shadow-sm" data-ps="src/components/destinations/greece/GreeceIslands.astro:14pwvi">
        <div class="absolute inset-0 bg-secondary/20 group-hover:bg-transparent transition-colors duration-500 z-10" data-ps="src/components/destinations/greece/GreeceIslands.astro:c0r4vq"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-secondary/90 via-secondary/40 to-transparent z-10" data-ps="src/components/destinations/greece/GreeceIslands.astro:c0r4vr"></div>
        <img src="https://images.pexels.com/photos/13538484/pexels-photo-13538484.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Zante" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" data-ps="src/components/destinations/greece/GreeceIslands.astro:ezjt4m" />
        <div class="absolute bottom-0 left-0 right-0 p-8 z-20" data-ps="src/components/destinations/greece/GreeceIslands.astro:c0r4vs">
          <h3 class="text-3xl font-serif font-bold text-white mb-2" data-ps="src/components/destinations/greece/GreeceIslands.astro:3igjf3">Zante</h3>
          <p class="text-white/80 text-sm" data-ps="src/components/destinations/greece/GreeceIslands.astro:88ntl8">Crystal clear waters & vibrant nightlife</p>
          <div class="mt-4 flex items-center text-white text-[10px] font-bold uppercase tracking-widest gap-2" data-ps="src/components/destinations/greece/GreeceIslands.astro:c0r4vt">
            Explore <svg class="w-4 h-4 group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </div>
        </div>
      </a>
    </div>
  </div>
</section>