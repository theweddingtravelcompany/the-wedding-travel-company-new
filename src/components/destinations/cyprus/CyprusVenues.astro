---
// Cyprus Venues Section
import { WishlistButton } from '@/components/wishlist/WishlistButton';
import { VenueImageSlider } from '@/components/destinations/VenueImageSlider';
---

<section class="py-24 px-6 bg-background" data-ps="src/components/destinations/cyprus/CyprusVenues.astro:2lumhl">
  <div class="max-w-7xl mx-auto" data-ps="src/components/destinations/cyprus/CyprusVenues.astro:1kosn4">
    <div class="text-center mb-16" data-ps="src/components/destinations/cyprus/CyprusVenues.astro:1kosn3">
      <h2 class="text-[42px] font-bold font-serif text-secondary mb-4" data-ps="src/components/destinations/cyprus/CyprusVenues.astro:jwby83">Your Dream Cyprus Wedding</h2>
      <p class="text-muted-foreground max-w-3xl mx-auto leading-relaxed" data-ps="src/components/destinations/cyprus/CyprusVenues.astro:cxglxd">
        Cyprus, the island of love, is one of the most popular wedding destinations for UK couples. With over 300 days of sunshine a year and a flight time of just 4.5 hours, it offers the perfect blend of Mediterranean charm and reliable weather.
      </p>
    </div>

    <div class="bg-surface rounded-2xl p-8 mb-12" data-ps="src/components/destinations/cyprus/CyprusVenues.astro:1kosn2">
      <div class="flex flex-wrap gap-6 justify-center text-[10px] font-bold uppercase tracking-widest" data-ps="src/components/destinations/cyprus/CyprusVenues.astro:1kosn1">
        <span class="flex items-center gap-2 text-secondary" data-ps="src/components/destinations/cyprus/CyprusVenues.astro:awj89u"><svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>English-speaking wedding specialists</span>
        <span class="flex items-center gap-2 text-secondary" data-ps="src/components/destinations/cyprus/CyprusVenues.astro:awj89t"><svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Legally recognised ceremonies</span>
        <span class="flex items-center gap-2 text-secondary" data-ps="src/components/destinations/cyprus/CyprusVenues.astro:awj89s"><svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Stunning sunset backdrops</span>
        <span class="flex items-center gap-2 text-secondary" data-ps="src/components/destinations/cyprus/CyprusVenues.astro:awj89r"><svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Exceptional hospitality & food</span>
      </div>
    </div>



    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8" data-ps="src/components/destinations/cyprus/CyprusVenues.astro:1kosqh">
      <!-- St Raphael Resort (FEATURED) -->
      <div class="bg-primary text-white border border-primary rounded-xl overflow-hidden shadow-sm hover:-translate-y-1 transition-transform flex flex-col h-full relative" data-ps="src/components/destinations/cyprus/CyprusVenues.astro:1kosqg">
        <div class="relative aspect-video overflow-hidden" data-ps="src/components/destinations/cyprus/CyprusVenues.astro:1kosqf">
          <VenueImageSlider client:load images={["https://images.unsplash.com/photo-1657306056630-620f09ef93dc?auto=format&w=800&q=80", "https://images.unsplash.com/photo-1519225421980-715cb0215aed?auto=format&w=800&q=80", "https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?auto=format&w=800&q=80"]} alt="St. Raphael Resort" />
