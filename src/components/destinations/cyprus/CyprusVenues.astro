          <div class="flex flex-col gap-5" data-ps="src/components/destinations/cyprus/CyprusVenues.astro:1kospl">
            <a href="/venues/st-raphael-resort" class="bg-white text-primary text-center py-4 rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-gray-100 transition-colors w-full" data-ps="src/components/destinations/cyprus/CyprusVenues.astro:wo8k5u">View Venue</a>
            <a href="/enquire2" class="text-white text-[10px] font-bold uppercase tracking-[2px] text-center hover:text-accent transition-colors" data-ps="src/components/destinations/cyprus/CyprusVenues.astro:wo8k6g">Enquire Now</a>
