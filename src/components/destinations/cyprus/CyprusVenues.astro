                <div class="relative w-2.5 h-2.5 rounded-full bg-[#e0e0e0] overflow-hidden" data-ps="src/components/destinations/cyprus/CyprusVenues.astro:1kosn5">
                  <div class="absolute top-0 left-0 bottom-0 w-[90%] bg-[#00aa6c]" data-ps="src/components/destinations/cyprus/CyprusVenues.astro:1kosn4"></div>
                </div>
