          <div class="flex items-end justify-between mb-6 mt-auto" data-ps="src/components/destinations/cyprus/CyprusVenues.astro:1kosos">
            <div class="flex flex-col" data-ps="src/components/destinations/cyprus/CyprusVenues.astro:1kosor">
