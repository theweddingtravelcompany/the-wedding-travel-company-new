---
// Cyprus Destination Hero
---

<section class="relative bg-secondary min-h-[600px] flex items-center py-20 px-6 overflow-hidden">
  <div class="absolute inset-0 z-0">
    <img
      crossorigin="anonymous"
      src="https://images.unsplash.com/photo-1758789791158-71e81950f70f?auto=format&w=1920&q=80"
      alt="Wedding in Cyprus"
      class="w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-secondary/50"></div>
  </div>

  <div class="max-w-7xl mx-auto w-full relative z-10 text-white">
    <h1 class="text-[48px] md:text-[72px] font-bold font-serif leading-tight mb-6">
      Weddings in Cyprus
    </h1>
    <p class="text-[24px] text-white/80 max-w-2xl mb-8">
      Award-winning destination wedding specialists trusted by 1,000+ couples each year.
    </p>
    <div class="flex flex-wrap gap-4 text-[10px] font-bold uppercase tracking-widest mb-8">
      <span>ABTA BONDED</span>
      <span>|</span>
      <span>0% INTEREST PAYMENT PLANS</span>
      <span>|</span>
      <span>IN-HOUSE LEGAL TEAM</span>
    </div>
    <p class="text-white/60 text-sm">Book up to 3 years ahead • Low deposits • Interest free monthly instalments</p>
    <a href="/enquire2" class="inline-block mt-8 bg-primary text-white px-8 py-4 rounded-xl font-bold uppercase tracking-widest text-[12px] hover:bg-primary-hover transition-colors">
      Get My Personalised Quote
    </a>
  </div>
</section>