---
// Venue Info, Gallery & Packages - Unified Layout
import { ReceptionManager } from '@/components/islands/ReceptionManager';
import { WishlistButton } from '@/components/wishlist/WishlistButton';
---

<ReceptionManager client:load />

<section class="py-0 md:py-8 px-0 md:px-6 bg-[#FAFAFA]" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:g27rf5">
  <div class="max-w-7xl mx-auto px-4 md:px-0" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:ygwgy0">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-12" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:ygwgy1">
      
      <!-- Left Column: Hero, Gallery, Info, Packages, Reception Options -->
      <div class="lg:col-span-8 space-y-8 md:space-y-12 contents lg:block" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:ygwgy2">
        
        <!-- NEW HERO & GALLERY -->
        <div class="space-y-1 md:space-y-4 lg:col-span-8 order-1 -mx-4 md:mx-0" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:ygwgy3">
          <!-- Main Hero Image with Overlay -->
          <div class="relative md:rounded-3xl overflow-hidden aspect-[4/3] md:aspect-[16/9]" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:ygwgyp">
            <img id="main-gallery-image" crossorigin="anonymous" src="https://images.unsplash.com/photo-1657306056630-620f09ef93dc?auto=format&w=1200&q=80" alt="St. Raphael Resort" class="w-full h-full object-cover transition-opacity duration-300" loading="eager" fetchpriority="high" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:vynclp" />
            
            <!-- Top Badges -->
            <div class="absolute top-4 left-4 right-4 flex justify-between items-start z-10" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:ygwgyr">
              <div class="bg-white px-3 py-1.5 rounded-full flex items-center gap-1.5 shadow-sm" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:ygwgys">
                <div class="flex items-center gap-0.5" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:tripadvisor-circles">
                  <div class="w-2.5 h-2.5 rounded-full bg-[#00aa6c]" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:circle-1"></div>
                  <div class="w-2.5 h-2.5 rounded-full bg-[#00aa6c]" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:circle-2"></div>
                  <div class="w-2.5 h-2.5 rounded-full bg-[#00aa6c]" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:circle-3"></div>
                  <div class="w-2.5 h-2.5 rounded-full bg-[#00aa6c]" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:circle-4"></div>
                  <div class="relative w-2.5 h-2.5 rounded-full bg-[#e0e0e0] overflow-hidden" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:circle-5">
                    <div class="absolute top-0 left-0 bottom-0 w-1/2 bg-[#00aa6c]" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:zhcasq"></div>
                  </div>
                </div>
                <span class="text-secondary font-bold text-xs ml-0.5" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:zb83m3">4.5</span>
              </div>
              <WishlistButton 
                client:load
                venue={{
                  id: "golden-coast-beach-hotel",
                  name: "Golden Coast Beach Hotel",
                  location: "Protaras, Cyprus",
                  priceFrom: "£2,455",
                  image: "https://images.unsplash.com/photo-1657306056630-620f09ef93dc?auto=format&w=400&q=80",
                  url: "/venues/st-raphael-resort/"
                }}
                iconOnly={true}
              />
            </div>

            <!-- Gallery Navigation Buttons -->
            <div class="absolute inset-y-0 left-2 right-2 flex items-center justify-between pointer-events-none" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:gallery-nav">
            <button id="gallery-prev" class="w-8 h-8 md:w-10 md:h-10 bg-white/90 hover:bg-white rounded-full flex items-center justify-center shadow-sm text-secondary transition-all pointer-events-auto active:scale-95" aria-label="Previous image" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:ixvqs1">
            <svg class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
            </button>
            <button id="gallery-next" class="w-8 h-8 md:w-10 md:h-10 bg-white/90 hover:bg-white rounded-full flex items-center justify-center shadow-sm text-secondary transition-all pointer-events-auto active:scale-95" aria-label="Next image" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:ixvqs2">
            <svg class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </button>
            </div>

            <!-- Bottom Text Overlay -->
            <div class="absolute bottom-4 md:bottom-6 left-4 md:left-6 right-4 md:left-6" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:ygwgyt">
            <h1 class="text-2xl md:text-5xl font-bold font-serif text-white mb-0.5 md:mb-2 drop-shadow-lg" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:a26ork">Golden Coast Beach Hotel</h1>
            <p class="text-white/90 flex items-center gap-1.5 text-base md:text-lg font-medium drop-shadow-md" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:csbjyv">
            <svg class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            Protaras, Cyprus
            </p>
            </div>
            </div>

          <!-- Thumbnails (Scrollable on mobile) -->
          <div class="flex overflow-x-auto py-2 -mx-4 px-4 gap-2 md:gap-4 snap-x snap-mandatory md:mx-0 md:px-0 md:grid md:grid-cols-5 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:ygwgyu">
             <div class="gallery-thumb w-20 md:w-full flex-shrink-0 rounded-xl md:rounded-2xl overflow-hidden aspect-square snap-start ring-2 ring-accent ring-inset cursor-pointer shadow-sm transition-all" data-highres="https://images.unsplash.com/photo-1657306056630-620f09ef93dc?auto=format&w=1200&q=80" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:ygwgyv">
               <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1657306056630-620f09ef93dc?auto=format&w=400&q=80" alt="St. Raphael Resort" class="w-full h-full object-cover" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:vynclq" />
             </div>
             <div class="gallery-thumb w-20 md:w-full flex-shrink-0 rounded-xl md:rounded-2xl overflow-hidden aspect-square snap-start opacity-60 hover:opacity-100 transition-all cursor-pointer shadow-sm ring-0 ring-accent ring-inset" data-highres="https://images.unsplash.com/photo-1763129636673-df7c37cf251d?auto=format&w=1200&q=80" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:ygwgyw">
               <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1763129636673-df7c37cf251d?auto=format&w=400&q=80" alt="St. Raphael Resort 2" class="w-full h-full object-cover" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:vynclr" />
             </div>
             <div class="gallery-thumb w-20 md:w-full flex-shrink-0 rounded-xl md:rounded-2xl overflow-hidden aspect-square snap-start opacity-60 hover:opacity-100 transition-all cursor-pointer shadow-sm ring-0 ring-accent ring-inset" data-highres="https://images.unsplash.com/photo-1767961054378-4092dbeb7c3b?auto=format&w=1200&q=80" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:ygwgyx">
               <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1767961054378-4092dbeb7c3b?auto=format&w=400&q=80" alt="St. Raphael Resort 3" class="w-full h-full object-cover" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:vyncls" />
             </div>
             <div class="gallery-thumb w-20 md:w-full flex-shrink-0 rounded-xl md:rounded-2xl overflow-hidden aspect-square snap-start opacity-60 hover:opacity-100 transition-all cursor-pointer shadow-sm ring-0 ring-accent ring-inset" data-highres="https://images.unsplash.com/photo-1639664341873-9a5ab1170013?auto=format&w=1200&q=80" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:ygwgyy">
               <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1639664341873-9a5ab1170013?auto=format&w=400&q=80" alt="St. Raphael Resort 4" class="w-full h-full object-cover" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:vyncme" />
             </div>
             <div class="gallery-thumb w-20 md:w-full flex-shrink-0 rounded-xl md:rounded-2xl overflow-hidden aspect-square snap-start opacity-60 hover:opacity-100 transition-all cursor-pointer shadow-sm ring-0 ring-accent ring-inset" data-highres="https://images.unsplash.com/photo-1762177446992-4cac5b44a05d?auto=format&w=1200&q=80" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:ygwgzk">
               <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1762177446992-4cac5b44a05d?auto=format&w=400&q=80" alt="St. Raphael Resort 5" class="w-full h-full object-cover" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:vyncmf" />
             </div>
          </div>
        </div>

        <!-- Venue Information -->
        <div class="pt-4 md:pt-8 space-y-6 md:space-y-8 lg:col-span-8 order-3 lg:order-none" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:ygwgzl">
          <!-- Section 1: Wedding Venue Information -->
          <div class="expandable-section" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:vyncmj">
            <div class="mb-4 md:mb-6" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:ygwh1g">
            <h2 class="text-2xl md:text-[28px] font-bold font-serif text-secondary" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:oqlluw">Wedding Venue Information</h2>
            </div>
            <div class="content-wrapper overflow-hidden transition-[max-height] duration-500 ease-in-out max-h-48 relative" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:ygwh1i">
              <div class="prose prose-lg text-muted-foreground leading-relaxed max-w-none" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:ygwh1j">
                <p data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:csbjtv">Situated against the backdrop of the stunning St Paul’s Bay in Lindos, St Paul’s Chapel is an iconic Greek wedding venue, and for good reason. Just beneath the famous landmark, the Acropolis of Lindos, this stunning chapel offers traditional whitewashed walls and a breathtaking view of the sea, for an idyllic setting for any romantic wedding in Greece.</p>
                <p data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:csbjtu">Only a short distance from the village of Lindos, you can enjoy a blend of authentic Greek architecture and golden sandy beaches with a St Paul's Bay Lindos wedding.</p>
                <p data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:csbjtt">Explore the cobblestone streets of the local village, then head to the beach and watch the dazzling sunset. You can even say your vows on the stunning shoreline.</p>
                <p data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:csbjts">If a magical atmosphere and vibrant local life are what you’re looking for, this is the perfect place to host your destination wedding in Rhodes.</p>
              </div>
              <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-[#FAFAFA] to-transparent pointer-events-none fade-overlay" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:zhcash"></div>
            </div>
            <button class="expand-button text-accent font-bold mt-4 hover:underline transition-all flex items-center gap-1" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:ixfm7y">
              Read more
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
          </div>

          <!-- Section 2: Weddings at the St Paul's Chapel -->
          <div class="expandable-section" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:vyncmk">
            <h2 class="text-xl md:text-2xl font-bold font-serif text-secondary mb-3 md:mb-6" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:oqlluv">Weddings at the St Paul's Chapel</h2>
            <div class="content-wrapper overflow-hidden transition-[max-height] duration-500 ease-in-out max-h-48 relative" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:zhcasi">
              <div class="prose prose-lg text-muted-foreground leading-relaxed max-w-none" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:zhcasj">
                <p data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:csbjtr">Weddings at St Paul’s Chapel in Rhodes are ideal for a classic, picturesque celebration, with a backdrop of the Aegean Sea, making for fabulous wedding photos and an unforgettable experience for all your guests.</p>
                <p data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:csbjtq">Your ceremony starts just outside ‌the chapel, where guests can enjoy private panoramic views of the coast. This venue encourages guests to enjoy the moment, and photographs in front of the chapel doors are not permitted.</p>
                <p data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:csbjtp">Once you’ve said your vows, you can make your way to one of the many local restaurants and tavernas to enjoy authentic Greek menus and delicious wines.</p>
                <p data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:csbjto">If you’d prefer a more lavish celebration, you can enjoy a champagne cruise to celebrate your wedding before your reception in the village of Lindos or head down to the shore for a beach wedding celebration.</p>
                <p class="font-bold" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:csbjtn">Please note: Weddings at St Paul's Chapel are held in an area sectioned off in front of the chapel. You will not be able to go inside the chapel or have photos taken directly in front of it</p>
              </div>
              <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-[#FAFAFA] to-transparent pointer-events-none fade-overlay" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:zhcask"></div>
            </div>
            <button class="expand-button text-accent font-bold mt-4 hover:underline transition-all flex items-center gap-1" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:ixfm7z">
              Read more
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
          </div>

          <!-- Section 3: Why Choose St Paul’s Chapel -->
          <div class="expandable-section" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:vyncml">
            <h2 class="text-xl md:text-2xl font-bold font-serif text-secondary mb-3 md:mb-6" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:oqlluu">Why Choose St Paul’s Chapel for Your Greek Wedding Package?</h2>
            <div class="content-wrapper overflow-hidden transition-[max-height] duration-500 ease-in-out max-h-48 relative" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:zhcasl">
              <div class="prose prose-lg text-muted-foreground leading-relaxed max-w-none" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:zhcasm">
                <p data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:csbjtm">A St Paul's Bay wedding is an extraordinary experience for you and all your guests, combining stunning natural sites with local charm and privacy.</p>
                <ul class="list-none space-y-3">
                  <li class="flex items-start gap-2" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:nzmpfm"><span class="text-accent mt-1" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:zibif6">♥</span> Private ceremony space with panoramic cliffside views</li>
                  <li class="flex items-start gap-2" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:nzmpfl"><span class="text-accent mt-1" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:zibifs">♥</span> Access to the infamous Acropolis of Lindos for unique wedding photos</li>
                  <li class="flex items-start gap-2" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:nzmpfk"><span class="text-accent mt-1" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:zibift">♥</span> Wide variety of bars, restaurants and tavernas for reception options</li>
                  <li class="flex items-start gap-2" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:nzmpfj"><span class="text-accent mt-1" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:zibifu">♥</span> Champagne cruise opportunities post ceremony</li>
                  <li class="flex items-start gap-2" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:nzmpfi"><span class="text-accent mt-1" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:zibifv">♥</span> Beautiful weather and beach access</li>
                </ul>
              </div>
              <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-[#FAFAFA] to-transparent pointer-events-none fade-overlay" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:zhcasn"></div>
            </div>
            <button class="expand-button text-accent font-bold mt-4 hover:underline transition-all flex items-center gap-1" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:ixfm80">
              Read more
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
          </div>

          <!-- Section 4: What’s included -->
          <div class="expandable-section" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:vyncmm">
            <h2 class="text-xl md:text-2xl font-bold font-serif text-secondary mb-3 md:mb-6" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:oqllut">What’s included in a St Paul’s Chapel Wedding Package?</h2>
            <div class="content-wrapper overflow-hidden transition-[max-height] duration-500 ease-in-out max-h-48 relative" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:zhcaso">
              <div class="prose prose-lg text-muted-foreground leading-relaxed max-w-none" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:zhcasp">
                <p data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:csbjt0">When you choose to book a beautiful St Paul’s Chapel wedding with The Wedding Travel Company, you’ll benefit from:</p>
                <ul class="list-none space-y-3">
                  <li class="flex items-start gap-2" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:nzmpfh"><span class="text-accent mt-1" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:zibifw">♥</span> UK-based wedding planning support</li>
                  <li class="flex items-start gap-2" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:nzmpev"><span class="text-accent mt-1" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:zibifx">♥</span> A private ceremony for up to 30 guests</li>
                  <li class="flex items-start gap-2" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:nzmpeu"><span class="text-accent mt-1" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:zibify">♥</span> Local coordinates on the ground in Rhodes</li>
                  <li class="flex items-start gap-2" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:nzmpet"><span class="text-accent mt-1" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:zibifz">♥</span> Ceremony set up in Lindos on the day</li>
                  <li class="flex items-start gap-2" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:nzmpes"><span class="text-accent mt-1" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:zibig0">♥</span> Legal document handling and event coordination</li>
                  <li class="flex items-start gap-2" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:nzmper"><span class="text-accent mt-1" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:zibig1">♥</span> Optional extras for reception venues, catering and live entertainment</li>
                </ul>
                <p class="mt-6" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:csbjsz">If you want to know more about the amenities available at St Paul’s Chapel Lindos, or you’re ready to make a booking, get in touch with our wedding planners today!</p>
              </div>
              <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-[#FAFAFA] to-transparent pointer-events-none fade-overlay" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:zhcasq"></div>
            </div>
            <button class="expand-button text-accent font-bold mt-4 hover:underline transition-all flex items-center gap-1" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:ixfm81">
              Read more
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Right Column: Sidebar -->
      <div class="lg:col-span-4 order-2 lg:order-none mt-2 md:mt-0" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:zhcasj">
        <div class="sticky top-24 bg-white rounded-2xl md:rounded-3xl p-6 md:p-8 shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-gray-100" data-ps="src/components/venues/st-raphael-resort/VenueInfo.astro:zhcask">
