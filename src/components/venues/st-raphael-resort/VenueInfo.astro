<script>
  // Wedding Packages Accordion Logic
  const packageCheckboxes = document.querySelectorAll('input[type="checkbox"][id^="pkg"]');
  
  packageCheckboxes.forEach(checkbox => {
    checkbox.addEventListener('change', (e) => {
      const target = e.target as HTMLInputElement;
      if (target.checked) {
        // Close other checkboxes
        packageCheckboxes.forEach(other => {
          if (other !== target) {
            (other as HTMLInputElement).checked = false;
          }
        });
      }
    });
  });

  // Expandable Sections
  const sections = document.querySelectorAll('.expandable-section');
  
  sections.forEach(section => {
    const button = section.querySelector('.expand-button');
    const wrapper = section.querySelector('.content-wrapper');
    const fade = section.querySelector('.fade-overlay');
    const inner = wrapper?.querySelector('.prose');

    if (button && wrapper && inner && fade) {
      button.addEventListener('click', () => {
        const isExpanded = wrapper.classList.contains('expanded');
        
        if (isExpanded) {
          // Collapse
          (wrapper as HTMLElement).style.maxHeight = '12rem'; // 48 units = 12rem
          button.innerHTML = 'Read more <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>';
          fade.classList.remove('opacity-0');
          wrapper.classList.remove('expanded');
          // Scroll back to top of section if button is far down
          section.scrollIntoView({ behavior: 'smooth', block: 'start' });
        } else {
          // Close other sections first
          sections.forEach(otherSection => {
            if (otherSection !== section) {
              const otherWrapper = otherSection.querySelector('.content-wrapper');
              const otherButton = otherSection.querySelector('.expand-button');
              const otherFade = otherSection.querySelector('.fade-overlay');
              if (otherWrapper && otherButton && otherFade && otherWrapper.classList.contains('expanded')) {
                (otherWrapper as HTMLElement).style.maxHeight = '12rem';
                otherButton.innerHTML = 'Read more <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>';
                otherFade.classList.remove('opacity-0');
                otherWrapper.classList.remove('expanded');
              }
            }
          });

          // Expand current
          const scrollHeight = inner.scrollHeight;
          (wrapper as HTMLElement).style.maxHeight = `${scrollHeight}px`;
          button.innerHTML = 'Read less <svg class="w-4 h-4 rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>';
          fade.classList.add('opacity-0');
          wrapper.classList.add('expanded');
        }
      });
    }
  });

  // Gallery Interactivity
  const mainImage = document.getElementById('main-gallery-image') as HTMLImageElement;
  const thumbs = document.querySelectorAll('.gallery-thumb');
  const prevBtn = document.getElementById('gallery-prev');
  const nextBtn = document.getElementById('gallery-next');
  let currentIndex = 0;

  function updateGallery(index: number) {
    const thumb = thumbs[index];
    if (!thumb || !mainImage) return;

    // Remove active state from all thumbs
    thumbs.forEach(t => {
      t.classList.remove('ring-2', 'opacity-100');
      t.classList.add('opacity-60', 'ring-0');
    });
    
    // Add active state to current thumb
    thumb.classList.remove('opacity-60', 'ring-0');
    thumb.classList.add('ring-2', 'opacity-100');
    
    // Update main image source
    const highResUrl = thumb.getAttribute('data-highres');
    if (highResUrl) {
      mainImage.classList.add('opacity-50');
      setTimeout(() => {
        mainImage.src = highResUrl;
        mainImage.classList.remove('opacity-50');
      }, 150);
    }

    // Ensure thumb is visible in scroll container on mobile
    thumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    currentIndex = index;
  }

  if (mainImage && thumbs.length > 0) {
    thumbs.forEach((thumb, idx) => {
      thumb.addEventListener('click', () => updateGallery(idx));
    });

    prevBtn?.addEventListener('click', () => {
      const nextIdx = (currentIndex - 1 + thumbs.length) % thumbs.length;
      updateGallery(nextIdx);
    });

    nextBtn?.addEventListener('click', () => {
      const nextIdx = (currentIndex + 1) % thumbs.length;
      updateGallery(nextIdx);
    });
  }
</script>