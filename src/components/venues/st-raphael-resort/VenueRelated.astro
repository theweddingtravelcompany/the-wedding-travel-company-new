---
// Related Venues Section
import { WishlistButton } from '@/components/wishlist/WishlistButton';
---

<section class="py-24 px-6 bg-surface" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:6t3nan">
  <div class="max-w-7xl mx-auto" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:ogh5ey">
    <div class="flex justify-between items-center mb-12" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:ogh5ez">
      <h2 class="text-[36px] font-bold font-serif text-secondary" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:lkk20z">More Wedding Venues in Cyprus</h2>
      <a href="/destinations/cyprus" class="text-primary font-bold text-sm hover:underline" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:seepnx">View all in Cyprus →</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:ogh5f0">
      <!-- Coral Beach Hotel & Resort -->
      <div class="bg-white rounded-xl overflow-hidden shadow-sm hover-lift" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:ogh5f1">
        <div class="relative aspect-video overflow-hidden" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:ogh5fn">
          <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1544551763-46a013bb70d5?auto=format&w=800&q=80" alt="Coral Beach Hotel & Resort" class="w-full h-full object-cover" loading="lazy" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:ly813e" />
          <div class="absolute top-4 right-4 z-10" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:ogh5fo">
          <WishlistButton 
          client:load
          venue={{
          id: "coral-beach-hotel",
          name: "Coral Beach Hotel & Resort",
          location: "Paphos, Cyprus",
          image: "https://images.unsplash.com/photo-1544551763-46a013bb70d5?auto=format&w=800&q=80",
          priceFrom: "£1,899",
          url: "/venues/coral-beach-hotel"
          }} 
          iconOnly={true} 
          />
          </div>
        </div>
        <div class="p-6" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:ogh5fp">
          <div class="flex items-center justify-between mb-4" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:ogh5fq">
            <p class="text-[10px] font-bold uppercase tracking-[2px] text-primary" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:lagszp">Paphos • Beachfront Resort</p>
            <span class="text-primary text-[10px] font-bold" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:3bi8fy">★ 4.8 (112)</span>
          </div>
          <h3 class="text-2xl font-bold font-serif text-secondary mb-3" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:ys52px">Coral Beach Hotel & Resort</h3>
          <p class="text-sm text-muted-foreground leading-relaxed mb-8" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:lagszq">A luxurious beachfront resort in Paphos offering breathtaking sea views and world-class wedding facilities.</p>
          <div class="flex items-end justify-between mb-6" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:ogh5fr">
            <div class="flex flex-col" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:ogh5fs">
              <span class="text-[10px] font-bold uppercase tracking-widest text-secondary mb-1" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:3bi8g0">From</span>
              <span class="text-2xl font-bold text-secondary" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:3bi8g1">£1,899</span>
            </div>
            <div class="text-[12px] text-muted-foreground text-right" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:8djpmo">Based on 30 guests</div>
          </div>
          <div class="flex flex-col gap-5" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:8djpmn">
            <a href="/venues/coral-beach-hotel" class="bg-accent text-white text-center py-4 rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-accent-hover transition-colors w-full" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:seepny">View Venue</a>
            <a href="/enquire2" class="text-primary text-[10px] font-bold uppercase tracking-[2px] text-center hover:opacity-80 transition-opacity" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:37gv31">Enquire Now</a>
          </div>
        </div>
      </div>

      <!-- Olympic Lagoon Resort -->
      <div class="bg-white rounded-xl overflow-hidden shadow-sm hover-lift" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:ogh5ft">
        <div class="relative aspect-video overflow-hidden" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:ogh5fu">
          <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&w=800&q=80" alt="Olympic Lagoon Resort" class="w-full h-full object-cover" loading="lazy" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:ly813f" />
          <div class="absolute top-4 right-4 z-10" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:ogh5fv">
          <WishlistButton 
          client:load
          venue={{
          id: "olympic-lagoon-paphos",
          name: "Olympic Lagoon Resort",
          location: "Paphos, Cyprus",
          image: "https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&w=800&q=80",
          priceFrom: "£2,799",
          url: "/venues/olympic-lagoon-paphos"
          }} 
          iconOnly={true} 
          />
          </div>
        </div>
        <div class="p-6" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:ogh5fw">
          <div class="flex items-center justify-between mb-4" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:8djpms">
            <p class="text-[10px] font-bold uppercase tracking-[2px] text-primary" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:lagszr">Paphos • Beachfront Resort</p>
            <span class="text-primary text-[10px] font-bold" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:3bi8g2">★ 4.9 (124)</span>
          </div>
          <h3 class="text-2xl font-bold font-serif text-secondary mb-3" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:ys52py">Olympic Lagoon Resort</h3>
          <p class="text-sm text-muted-foreground leading-relaxed mb-8" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:lagszs">The ultimate luxury wedding destination with multiple ceremony and reception venues to choose from.</p>
          <div class="flex items-end justify-between mb-6" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:8djpmr">
            <div class="flex flex-col" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:8djpmq">
              <span class="text-[10px] font-bold uppercase tracking-widest text-secondary mb-1" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:3bi8g4">From</span>
              <span class="text-2xl font-bold text-secondary" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:3bi8g5">£2,799</span>
            </div>
            <div class="text-[12px] text-muted-foreground text-right" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:8djpmm">Based on 20 guests</div>
          </div>
          <div class="flex flex-col gap-5" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:8djpml">
            <a href="/venues/olympic-lagoon-paphos" class="bg-accent text-white text-center py-4 rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-accent-hover transition-colors w-full" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:seepnz">View Venue</a>
            <a href="/enquire2" class="text-primary text-[10px] font-bold uppercase tracking-[2px] text-center hover:opacity-80 transition-opacity" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:37gv32">Enquire Now</a>
          </div>
        </div>
      </div>

      <!-- Cap St Georges Hotel -->
      <div class="bg-white rounded-xl overflow-hidden shadow-sm hover-lift" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:8djpmp">
        <div class="relative aspect-video overflow-hidden" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:8djpmo">
          <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1582719508461-905c673771fd?auto=format&w=800&q=80" alt="Cap St Georges Hotel" class="w-full h-full object-cover" loading="lazy" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:ly813g" />
          <div class="absolute top-4 right-4 z-10" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:8djpmn">
