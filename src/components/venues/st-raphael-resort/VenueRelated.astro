                location: "Paphos, Cyprus",
                image: "https://images.unsplash.com/photo-1582719508461-905c673771fd?auto=format&w=800&q=80",
                priceFrom: "£3,499",
                url: "/venues/cap-st-georges"
              }} 
              iconOnly={true} 
            />
          </div>
        </div>
        <div class="p-6" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:8djpmm">
          <div class="flex items-center justify-between mb-4" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:8djpml">
            <p class="text-[10px] font-bold uppercase tracking-[2px] text-primary" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:lagszt">Paphos • Boutique Hotel</p>
            <span class="text-primary text-[10px] font-bold" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:3bi8g6">★ 5 (87)</span>
          </div>
          <h3 class="text-2xl font-bold font-serif text-secondary mb-3" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:ys52qk">Cap St Georges Hotel</h3>
          <p class="text-sm text-muted-foreground leading-relaxed mb-8" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:lagszu">An exclusive boutique retreat offering privacy and sophistication for the most discerning couples.</p>
          <div class="flex items-end justify-between mb-6" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:8djpmk">
            <div class="flex flex-col" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:8djpmj">
              <span class="text-[10px] font-bold uppercase tracking-widest text-secondary mb-1" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:3bi8gt">From</span>
              <span class="text-2xl font-bold text-secondary" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:3bi8gu">£3,499</span>
