            <a href="/enquire2" class="text-primary text-[10px] font-bold uppercase tracking-[2px] text-center hover:opacity-80 transition-opacity" data-ps="src/components/venues/st-raphael-resort/VenueRelated.astro:37gv33">Enquire Now</a>
